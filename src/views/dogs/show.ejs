<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container">
  <section class="page-hero">
    <div>
      <p class="eyebrow">Fiche cynotechnique</p>
      <h1><%= dog.name %></h1>
      <p>
        <%= dog.breed || 'Race non renseignée' %>
        —
        <%= dog.sex === 'M' ? 'Mâle' : 'Femelle' %>
      </p>
    </div>
    <div class="topbar-actions">
      <a class="btn btn-secondary" href="/dogs">Retour</a>
      <a class="btn btn-primary" href="/dogs/<%= dog.id %>/edit">Modifier</a>
    </div>
  </section>

  <section class="kpi-grid">
    <article class="kpi-card"><span>Statut</span><strong><%= dog.status || '-' %></strong></article>
    <article class="kpi-card"><span>Puce</span><strong><%= dog.chip_number || '-' %></strong></article>
    <article class="kpi-card"><span>Naissance</span><strong><%= dog.birth_date ? formatDate(dog.birth_date) : '-' %></strong></article>
    <article class="kpi-card"><span>LOF</span><strong><%= dog.lof || dog.pedigree_number || '-' %></strong></article>
  </section>

  <section class="dashboard-columns">
    <article class="card">
      <div class="section-title compact">
        <span class="section-kicker">Identité</span>
        <h2>Informations générales</h2>
      </div>
      <p><strong>Nom :</strong> <%= dog.name %></p>
      <p><strong>Race :</strong> <%= dog.breed || '-' %></p>
      <p><strong>Sexe :</strong> <%= dog.sex === 'M' ? 'Mâle' : 'Femelle' %></p>
      <p><strong>N° puce :</strong> <%= dog.chip_number || '-' %></p>
      <p><strong>ID SCC :</strong> <%= dog.id_scc || '-' %></p>
      <p><strong>Père :</strong> <%= dog.father_name || '-' %></p>
      <p><strong>Mère :</strong> <%= dog.mother_name || '-' %></p>
    </article>

    <article class="card">
      <div class="section-title compact">
        <span class="section-kicker">Notes</span>
        <h2>Observations</h2>
      </div>
      <p><%= dog.notes || 'Aucune observation renseignée.' %></p>
    </article>
  </section>

  <section class="dashboard-columns">
    <article class="table-block">
      <div class="section-title compact">
        <span class="section-kicker">Santé</span>
        <h2>Soins récents</h2>
      </div>
      <% if (!soins.length) { %>
        <p class="muted">Aucun soin enregistré pour ce chien.</p>
      <% } else { %>
        <table>
          <thead><tr><th>Date</th><th>Acte</th><th>Échéance</th></tr></thead>
          <tbody>
            <% soins.forEach((soin) => { %>
              <tr>
                <td><%= formatDate(soin.event_date) %></td>
                <td><%= soin.label %> <small>(<%= soin.type %>)</small></td>
                <td><%= soin.next_due ? formatDate(soin.next_due) : '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
      <div style="margin-top: 1rem;">
        <a class="btn btn-secondary" href="/soins">Ajouter un soin</a>
      </div>
    </article>

    <article class="table-block">
      <div class="section-title compact">
        <span class="section-kicker">Prioritaire</span>
        <h2>Rappels à venir</h2>
      </div>
      <% if (!reminders.length) { %>
        <p class="muted">Aucun rappel actif.</p>
      <% } else { %>
        <table>
          <thead><tr><th>Date</th><th>Libellé</th></tr></thead>
          <tbody>
            <% reminders.forEach((reminder) => { %>
              <tr>
                <td><%= formatDate(reminder.due_date) %></td>
                <td><%= reminder.title %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </article>
  </section>

  <section class="dashboard-columns">
    <article class="table-block">
      <div class="section-title compact">
        <span class="section-kicker">Reproduction</span>
        <h2>Portées liées</h2>
      </div>
      <% if (!litters.length) { %>
        <p class="muted">Aucune portée enregistrée pour cette chienne.</p>
      <% } else { %>
        <table>
          <thead><tr><th>Date</th><th>Nombre</th></tr></thead>
          <tbody>
            <% litters.forEach((litter) => { %>
              <tr>
                <td><%= formatDate(litter.birth_date) %></td>
                <td><%= litter.puppies_count_total || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </article>

    <article class="table-block">
      <div class="section-title compact">
        <span class="section-kicker">Descendance</span>
        <h2>Chiots issus des portées</h2>
      </div>
      <% if (!puppies.length) { %>
        <p class="muted">Aucun chiot rattaché à cette chienne.</p>
      <% } else { %>
        <table>
          <thead><tr><th>Nom</th><th>Sexe</th><th>Statut</th></tr></thead>
          <tbody>
            <% puppies.forEach((puppy) => { %>
              <tr>
                <td><a href="/puppies/<%= puppy.id %>"><%= puppy.name || 'Chiot sans nom' %></a></td>
                <td><%= puppy.sex || '-' %></td>
                <td><span class="badge"><%= puppy.status || '-' %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </article>
  </section>
</main>

<%- include('../partials/foot') %>
