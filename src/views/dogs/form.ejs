<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container">
    <div class="header-actions">
        <h1><%= dog.id ? "Modifier le profil de" : "Ajouter un chien" %> <%= dog.name || "" %></h1>
        <a href="/dogs" class="btn btn-secondary">Annuler et retour</a>
    </div>

    <form action="<%= dog.id ? '/dogs/' + dog.id + '/edit' : '/dogs/new' %>" method="POST" class="card form-block">
        
        <h3 style="color: var(--primary-color); border-bottom: 1px solid #eee; padding-bottom: 0.5rem; margin-bottom: 1.5rem;">Identité</h3>
        <div class="form-grid">
            <div class="form-group">
                <label>Nom du chien *</label>
                <input type="text" name="name" value="<%= dog.name || '' %>" required>
            </div>
            <div class="form-group">
                <label>Sexe *</label>
                <select name="sex" required>
                    <option value="M" <%= dog.sex === 'M' ? 'selected' : '' %>>Mâle</option>
                    <option value="F" <%= dog.sex === 'F' ? 'selected' : '' %>>Femelle</option>
                </select>
            </div>
            <div class="form-group">
                <label>Race</label>
                <input type="text" name="breed" value="<%= dog.breed || '' %>">
            </div>
            <div class="form-group">
                <label>Date de naissance</label>
                <input type="date" name="birth_date" value="<%= dog.birth_date ? new Date(dog.birth_date).toISOString().split('T')[0] : '' %>">
            </div>
        </div>

        <h3 style="color: var(--primary-color); border-bottom: 1px solid #eee; padding-bottom: 0.5rem; margin-top: 2rem; margin-bottom: 1.5rem;">Traçabilité & SCC</h3>
        <div class="form-grid">
            <div class="form-group">
                <label>Numéro de Puce / Tatouage</label>
                <input type="text" name="chip_number" value="<%= dog.chip_number || '' %>">
            </div>
            <div class="form-group">
                <label>Numéro LOF</label>
                <input type="text" name="lof" value="<%= dog.lof || '' %>">
            </div>
            <div class="form-group">
                <label>Identifiant SCC</label>
                <input type="text" name="id_scc" value="<%= dog.id_scc || '' %>">
            </div>
            <div class="form-group">
                <label>Numéro de Pedigree</label>
                <input type="text" name="pedigree_number" value="<%= dog.pedigree_number || '' %>">
            </div>
        </div>

        <h3 style="color: var(--primary-color); border-bottom: 1px solid #eee; padding-bottom: 0.5rem; margin-top: 2rem; margin-bottom: 1.5rem;">Généalogie</h3>
        <div class="form-grid">
            <!-- PÈRE -->
            <div class="card" style="padding: 1rem; background-color: #f8f9fa; border: 1px solid #e9ecef; box-shadow: none;">
                <h4 style="margin-top: 0; font-size: 1.1rem;">Père</h4>
                <div class="form-group">
                    <label>Père issu de l'élevage</label>
                    <select id="father_id" name="father_id">
                        <option value="">-- Sélectionner un mâle --</option>
                        <% males.forEach(m => { %>
                            <option value="<%= m.id %>" <%= dog.father_id === m.id ? 'selected' : '' %>><%= m.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-group" style="margin-top: 1rem;">
                    <label>OU Père externe (Saisie manuelle)</label>
                    <input type="text" id="father_name_external" name="father_name_external" value="<%= dog.father_name_external || '' %>" placeholder="Nom du père externe">
                </div>
            </div>

            <!-- MÈRE -->
            <div class="card" style="padding: 1rem; background-color: #f8f9fa; border: 1px solid #e9ecef; box-shadow: none;">
                <h4 style="margin-top: 0; font-size: 1.1rem;">Mère</h4>
                <div class="form-group">
                    <label>Mère issue de l'élevage</label>
                    <select id="mother_id" name="mother_id">
                        <option value="">-- Sélectionner une femelle --</option>
                        <% females.forEach(f => { %>
                            <option value="<%= f.id %>" <%= dog.mother_id === f.id ? 'selected' : '' %>><%= f.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-group" style="margin-top: 1rem;">
                    <label>OU Mère externe (Saisie manuelle)</label>
                    <input type="text" id="mother_name_external" name="mother_name_external" value="<%= dog.mother_name_external || '' %>" placeholder="Nom de la mère externe">
                </div>
            </div>
        </div>

        <h3 style="color: var(--primary-color); border-bottom: 1px solid #eee; padding-bottom: 0.5rem; margin-top: 2rem; margin-bottom: 1.5rem;">Informations internes</h3>
        <div class="form-grid">
            <div class="form-group">
                <label>Statut dans l'élevage</label>
                <select name="status">
                    <option value="actif" <%= dog.status === 'actif' ? 'selected' : '' %>>Actif (Reproducteur)</option>
                    <option value="inactif" <%= dog.status === 'inactif' ? 'selected' : '' %>>Inactif</option>
                    <option value="retraite" <%= dog.status === 'retraite' ? 'selected' : '' %>>À la retraite</option>
                    <option value="decede" <%= dog.status === 'decede' ? 'selected' : '' %>>Décédé</option>
                </select>
            </div>
        </div>
        <div class="form-group" style="margin-top: 1rem;">
            <label>Notes / Observations</label>
            <textarea name="notes" rows="4"><%= dog.notes || '' %></textarea>
        </div>

        <div style="margin-top: 3rem; padding-top: 2rem; border-top: 2px solid #eee;">
            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1.2rem; font-size: 1.2rem; font-weight: bold;">
                Enregistrer le profil
            </button>
        </div>
    </form>
</main>

<script>
document.addEventListener("DOMContentLoaded", function() {
    const fatherSelect = document.getElementById('father_id');
    const fatherInput = document.getElementById('father_name_external');
    const motherSelect = document.getElementById('mother_id');
    const motherInput = document.getElementById('mother_name_external');

    function toggleFields() {
        if (fatherSelect.value !== "") {
            fatherInput.value = "";
            fatherInput.disabled = true;
            fatherInput.style.backgroundColor = "#e9ecef";
        } else {
            fatherInput.disabled = false;
            fatherInput.style.backgroundColor = "";
        }

        if (motherSelect.value !== "") {
            motherInput.value = "";
            motherInput.disabled = true;
            motherInput.style.backgroundColor = "#e9ecef";
        } else {
            motherInput.disabled = false;
            motherInput.style.backgroundColor = "";
        }
    }

    fatherSelect.addEventListener('change', toggleFields);
    motherSelect.addEventListener('change', toggleFields);

    // Initialisation
    toggleFields();
});
</script>

<%- include('../partials/foot') %>