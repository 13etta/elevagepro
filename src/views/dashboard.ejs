<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="container">
  <section class="page-hero dashboard-hero">
    <div>
      <p class="eyebrow"><%= __('dashboard.kicker') %></p>
      <h1><%= __('dashboard.title') %></h1>
      <p><%= __('dashboard.subtitle') %></p>
    </div>
    <a class="btn btn-primary" href="/dogs"><%= __('dashboard.primaryAction') %></a>
  </section>

  <% if (typeof alerts !== 'undefined' && alerts.length) { %>
    <section class="alert-grid">
      <% alerts.forEach((alert) => { %>
        <a class="business-alert alert-<%= alert.level %>" href="<%= alert.href %>">
          <span><%= alert.level === 'danger' ? '!' : alert.level === 'warning' ? '⚠' : 'i' %></span>
          <strong><%= alert.title %></strong>
        </a>
      <% }) %>
    </section>
  <% } %>

  <section class="dashboard-kpi-grid">
    <article class="kpi-card kpi-gauge-card">
      <span>Occupation des box</span>
      <div class="dashboard-gauge" style="--value:<%= kpis.boxOccupancyRate %>;">
        <div class="dashboard-gauge-inner">
          <strong><%= kpis.boxOccupancyRate %>%</strong>
          <small><%= kpis.activeDogs %> / <%= kpis.boxCapacity %> places</small>
        </div>
      </div>
      <p class="muted">Capacité configurable via KENNEL_BOX_CAPACITY.</p>
    </article>

    <article class="kpi-card">
      <span>Chiots disponibles</span>
      <strong><%= kpis.availablePuppies %></strong>
      <small class="muted"><%= kpis.reservedPuppies %> réservé(s) ou sous option</small>
    </article>

    <article class="kpi-card">
      <span>Ventes du mois</span>
      <strong><%= formatCurrency(kpis.currentMonthSales) %></strong>
      <small class="muted"><%= kpis.incompleteSales %> vente(s) à finaliser</small>
    </article>

    <article class="kpi-card">
      <span>Rappels à 7 jours</span>
      <strong><%= kpis.upcomingReminders %></strong>
      <small class="muted">Priorités sanitaires et administratives</small>
    </article>

    <article class="kpi-card">
      <span>Portées actives</span>
      <strong><%= kpis.activeLitters %></strong>
      <small class="muted"><%= kpis.ongoingPregnancies %> gestation(s) en cours</small>
    </article>
  </section>

  <section class="dashboard-columns dashboard-priority-zone">
    <article class="table-block dashboard-sales-panel">
      <div class="section-title compact">
        <span class="section-kicker">Pilotage commercial</span>
        <h2>Ventes mensuelles</h2>
      </div>

      <% if (!salesSeries || !salesSeries.length) { %>
        <p class="muted">Aucune donnée de vente à afficher.</p>
      <% } else { %>
        <div class="mini-bar-chart" aria-label="Graphique des ventes mensuelles">
          <% salesSeries.forEach((item) => { %>
            <div class="mini-bar-item">
              <div class="mini-bar-track">
                <div class="mini-bar-fill" style="height:<%= Math.max(5, Math.round((item.total / maxMonthlySales) * 100)) %>%"></div>
              </div>
              <small><%= item.label %></small>
              <strong><%= formatCurrency(item.total) %></strong>
            </div>
          <% }) %>
        </div>
      <% } %>
    </article>

    <article class="table-block">
      <div class="section-title compact">
        <span class="section-kicker"><%= __('dashboard.priority') %></span>
        <h2><%= __('dashboard.reminders') %></h2>
      </div>
      <% if (!reminders.length) { %>
        <p class="muted">Aucun rappel prioritaire.</p>
      <% } else { %>
        <table>
          <thead><tr><th><%= __('common.date') %></th><th><%= __('common.label') %></th><th><%= __('common.dog') %></th></tr></thead>
          <tbody>
            <% reminders.forEach((row) => { %>
              <tr class="<%= new Date(row.due_date) < new Date() ? 'late' : '' %>">
                <td><%= formatDate(row.due_date) %></td>
                <td><%= row.label %><br><small><%= row.scope || '' %></small></td>
                <td><%= row.dog_name || __('common.general') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </article>
  </section>

  <section class="dashboard-columns dashboard-priority-zone">
    <article class="table-block">
      <div class="section-title compact">
        <span class="section-kicker"><%= __('dashboard.recent') %></span>
        <h2><%= __('dashboard.care') %></h2>
      </div>
      <% if (!soins.length) { %>
        <p class="muted">Aucun soin récent.</p>
      <% } else { %>
        <table>
          <thead><tr><th><%= __('common.date') %></th><th><%= __('common.type') %></th><th><%= __('common.dog') %></th></tr></thead>
          <tbody>
            <% soins.forEach((row) => { %>
              <tr>
                <td><%= formatDate(row.event_date) %></td>
                <td><%= row.label || row.type %></td>
                <td><%= row.dog_name || __('common.general') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </article>

    <article class="table-block">
      <div class="section-title compact">
        <span class="section-kicker">Commercial</span>
        <h2>Dernières ventes</h2>
      </div>
      <% if (!sales.length) { %>
        <p class="muted">Aucune vente récente.</p>
      <% } else { %>
        <table>
          <thead><tr><th>Date</th><th>Acquéreur</th><th>Montant</th></tr></thead>
          <tbody>
            <% sales.forEach((sale) => { %>
              <tr>
                <td><%= formatDate(sale.sale_date) %></td>
                <td><%= sale.buyer_firstname || '-' %></td>
                <td><%= formatCurrency(sale.total_price) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </article>
  </section>

  <% if ((typeof salesToFinalize !== 'undefined' && salesToFinalize.length) || (typeof littersWithoutPuppies !== 'undefined' && littersWithoutPuppies.length)) { %>
    <section class="dashboard-columns dashboard-priority-zone">
      <article class="table-block">
        <div class="section-title compact">
          <span class="section-kicker">Commercial</span>
          <h2>Ventes incomplètes</h2>
        </div>
        <% if (!salesToFinalize.length) { %>
          <p class="muted">Aucune réservation à finaliser.</p>
        <% } else { %>
          <table>
            <thead><tr><th>Animal</th><th>Acquéreur</th><th>Solde</th><th>Action</th></tr></thead>
            <tbody>
              <% salesToFinalize.forEach((sale) => { %>
                <tr>
                  <td><%= sale.animal_name || '-' %></td>
                  <td><%= sale.buyer_name || '-' %></td>
                  <td><%= formatCurrency(Math.max(Number(sale.price || 0) - Number(sale.deposit_amount || 0), 0)) %></td>
                  <td><a class="btn btn-secondary" href="/sales/<%= sale.id %>/edit">Finaliser</a></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </article>

      <article class="table-block">
        <div class="section-title compact">
          <span class="section-kicker">Portées</span>
          <h2>Actions manquantes</h2>
        </div>
        <% if (!littersWithoutPuppies.length) { %>
          <p class="muted">Aucune portée sans chiots.</p>
        <% } else { %>
          <table>
            <thead><tr><th>Date</th><th>Mère</th><th>Action</th></tr></thead>
            <tbody>
              <% littersWithoutPuppies.forEach((litter) => { %>
                <tr>
                  <td><%= formatDate(litter.birth_date) %></td>
                  <td><%= litter.mother_name || '-' %></td>
                  <td><a class="btn btn-secondary" href="/litters/<%= litter.id %>">Ouvrir</a></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </article>
    </section>
  <% } %>

  <section class="module-cockpit">
    <div class="section-title">
      <span class="section-kicker"><%= __('dashboard.modulesKicker') %></span>
      <h2><%= __('dashboard.modulesTitle') %></h2>
    </div>

    <div class="module-grid">
      <% modules.filter((module) => module.key !== 'dashboard').forEach((module) => { %>
        <a class="module-card accent-<%= module.accent %>" href="<%= module.href %>">
          <span class="module-icon"><%= module.icon %></span>
          <strong><%= __(module.labelKey) %></strong>
          <p><%= __(module.descriptionKey) %></p>
        </a>
      <% }) %>
    </div>
  </section>
</main>

<%- include('partials/foot') %>
