<%- include('partials/head') %>
<%- include('partials/nav') %>
<main class="container">
  <h1>Dashboard</h1>
  <section class="kpi-grid">
    <article class="card"><h2>Chiens actifs</h2><strong><%= kpis.activeDogs %></strong></article>
    <article class="card"><h2>Chiots disponibles</h2><strong><%= kpis.availablePuppies %></strong></article>
    <article class="card"><h2>Portées actives</h2><strong><%= kpis.activeLitters %></strong></article>
    <article class="card"><h2>Gestations en cours</h2><strong><%= kpis.ongoingPregnancies %></strong></article>
  </section>

  <section class="table-block">
    <h3>Rappels prioritaires</h3>
    <table>
      <thead><tr><th>Échéance</th><th>Libellé</th><th>Chien</th></tr></thead>
      <tbody>
        <% reminders.forEach((row) => { %>
          <tr class="<%= new Date(row.due_date) < new Date() ? 'late' : '' %>">
            <td><%= formatDate(row.due_date) %></td>
            <td><%= row.label %></td>
            <td><%= row.dog_name || 'Général' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </section>

  <section class="table-block">
    <h3>Soins récents</h3>
    <table>
      <thead><tr><th>Date</th><th>Type</th><th>Libellé</th><th>Chien</th></tr></thead>
      <tbody>
        <% soins.forEach((row) => { %>
          <tr>
            <td><%= formatDate(row.event_date) %></td>
            <td><%= row.type %></td>
            <td><%= row.label %></td>
            <td><%= row.dog_name || 'Général' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </section>

  <section class="table-block">
    <h3>Dernières ventes</h3>
    <table>
      <thead><tr><th>Date</th><th>Acheteur</th><th>Montant</th></tr></thead>
      <tbody>
        <% sales.forEach((row) => { %>
          <tr>
            <td><%= formatDate(row.sale_date) %></td>
            <td><%= `${row.buyer_firstname || ''} ${row.buyer_lastname || ''}`.trim() || '-' %></td>
            <td><%= row.total_price ? `${row.total_price} €` : '-' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </section>
</main>
<%- include('partials/foot') %>
