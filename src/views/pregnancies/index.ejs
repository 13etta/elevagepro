<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container">
    <div class="header-actions" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
        <div>
            <h1>Suivi des Gestations</h1>
            <p style="color: #7f8c8d; margin-top:-0.5rem;">Gestion des étapes de reproduction, de la saillie à la mise bas</p>
        </div>
        <a href="/pregnancies/new" class="btn btn-primary">Ajouter une gestation</a>
    </div>

    <form method="GET" action="/pregnancies" class="card form-grid" style="margin-bottom: 2rem; padding: 1.5rem; background-color: #f8f9fa; border: 1px solid #e9ecef;">
        <div style="display: flex; gap: 1rem; flex-wrap: wrap; width: 100%;">
            <input type="text" name="q" placeholder="Rechercher (femelle, notes...)" value="<%= filters && filters.q ? filters.q : '' %>" style="flex: 2; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;">
            
            <select name="female" style="flex: 1; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;">
                <option value="">-- Femelle --</option>
                <% females.forEach(f => { %>
                    <option value="<%= f.id %>" <%= filters && filters.female == f.id ? 'selected' : '' %>><%= f.name %></option>
                <% }) %>
            </select>

            <select name="status" style="flex: 1; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;">
                <option value="">-- Statut --</option>
                <option value="En cours" <%= filters && filters.status === 'En cours' ? 'selected' : '' %>>En cours</option>
                <option value="Réussie" <%= filters && filters.status === 'Réussie' ? 'selected' : '' %>>Réussie</option>
                <option value="Échec" <%= filters && filters.status === 'Échec' ? 'selected' : '' %>>Échec</option>
            </select>

            <button type="submit" class="btn btn-secondary">Filtrer</button>
            <a href="/pregnancies" class="btn btn-outline-secondary" style="display: flex; align-items: center; text-decoration: none; color: #6c757d; border: 1px solid #ccc; padding: 0.5rem 1rem; border-radius: 4px;">Reset</a>
        </div>
    </form>

    <section class="card">
        <% if (pregnancies.length === 0) { %>
            <p style="text-align: center; color: #7f8c8d; padding: 3rem;">Aucune gestation enregistrée pour le moment.</p>
        <% } else { %>
            <div class="table-responsive">
                <table class="table" style="width: 100%; text-align: left; border-collapse: collapse;">
                    <thead style="background-color: #f8f9fa; border-bottom: 2px solid #dee2e6;">
                        <tr>
                            <th style="padding: 1rem;">Femelle</th>
                            <th style="padding: 1rem;">Début (Saillie)</th>
                            <th style="padding: 1rem;">Mise bas prévue</th>
                            <th style="padding: 1rem;">Statut</th>
                            <th style="padding: 1rem;">Notes</th>
                            <th style="padding: 1rem; text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% pregnancies.forEach(p => { %>
                            <tr style="border-bottom: 1px solid #eee;">
                                <td style="padding: 1rem;"><strong><%= p.female_name %></strong></td>
                                <td style="padding: 1rem;"><%= new Date(p.start_date).toLocaleDateString('fr-FR') %></td>
                                <td style="padding: 1rem;"><%= p.expected_date ? new Date(p.expected_date).toLocaleDateString('fr-FR') : '-' %></td>
                                <td style="padding: 1rem;">
                                    <% if (p.result === 'En cours') { %>
                                        <span style="background-color: #fff3cd; color: #856404; padding: 0.3rem 0.6rem; border-radius: 4px; font-size: 0.85rem; font-weight: bold;">En cours</span>
                                    <% } else if (p.result === 'Réussie') { %>
                                        <span style="background-color: #e8fdf5; color: #198754; padding: 0.3rem 0.6rem; border-radius: 4px; font-size: 0.85rem; font-weight: bold;">Réussie</span>
                                    <% } else if (p.result === 'Échec') { %>
                                        <span style="background-color: #ffeaea; color: #dc3545; padding: 0.3rem 0.6rem; border-radius: 4px; font-size: 0.85rem; font-weight: bold;">Échec</span>
                                    <% } %>
                                </td>
                                <td style="padding: 1rem; color: #666; font-size: 0.9rem; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    <%= p.notes || '-' %>
                                </td>
                                <td style="padding: 1rem; text-align: right; display: flex; justify-content: flex-end; gap: 0.5rem;">
                                    <a href="/pregnancies/<%= p.id %>/edit" class="btn btn-secondary btn-sm">Modifier</a>
                                    <form action="/pregnancies/<%= p.id %>/delete" method="POST" onsubmit="return confirm('Supprimer cette gestation ?');" style="margin:0;">
                                        <button type="submit" class="btn btn-sm" style="background-color: #ffeaea; color: #dc3545; border: 1px solid #ffc2c2;">Supprimer</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </section>
</main>

<%- include('../partials/foot') %>