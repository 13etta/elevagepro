<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container">
    <div class="header-actions">
        <h1><%= preg.id ? "Modifier la" : "Nouvelle" %> gestation</h1>
        <a href="/pregnancies" class="btn btn-secondary">Annuler</a>
    </div>

    <form action="<%= preg.id ? '/pregnancies/' + preg.id + '/edit' : '/pregnancies/new' %>" method="POST" class="card form-block">
        <input type="hidden" name="mating_id" value="<%= preg.mating_id || '' %>">

        <div class="form-grid">
            <div class="form-group">
                <label>Femelle *</label>
                <select name="female_id" required>
                    <option value="">-- Sélectionner --</option>
                    <% females.forEach(f => { %>
                        <option value="<%= f.id %>" <%= preg.female_id === f.id ? 'selected' : '' %>><%= f.name %></option>
                    <% }) %>
                </select>
            </div>
            <div class="form-group">
                <label>Date début (Saillie) *</label>
                <input type="date" id="start_date" name="start_date" value="<%= preg.start_date ? new Date(preg.start_date).toISOString().split('T')[0] : '' %>" required>
            </div>
        </div>

        <div class="form-grid" style="margin-top: 1rem;">
            <div class="form-group">
                <label>Date prévue de mise bas</label>
                <input type="date" id="expected_date" name="expected_date" value="<%= preg.expected_date ? new Date(preg.expected_date).toISOString().split('T')[0] : '' %>">
            </div>
            <div class="form-group">
                <label>Date réelle de mise bas</label>
                <input type="date" name="due_date" value="<%= preg.due_date ? new Date(preg.due_date).toISOString().split('T')[0] : '' %>">
            </div>
        </div>

        <div class="form-group" style="margin-top: 1rem;">
            <label>Résultat / Statut</label>
            <select name="result">
                <option value="En cours" <%= preg.result === 'En cours' ? 'selected' : '' %>>En cours</option>
                <option value="Réussie" <%= preg.result === 'Réussie' ? 'selected' : '' %>>Réussie</option>
                <option value="Échec" <%= preg.result === 'Échec' ? 'selected' : '' %>>Échec</option>
            </select>
        </div>

        <div class="form-group" style="margin-top: 1rem;">
            <label>Notes / Suivi vétérinaire</label>
            <textarea name="notes" rows="3"><%= preg.notes || '' %></textarea>
        </div>

        <div style="margin-top: 2rem;">
            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem;">Enregistrer</button>
        </div>
    </form>
</main>

<script>
document.addEventListener("DOMContentLoaded", function() {
    const startDateInput = document.getElementById("start_date");
    const expectedDateInput = document.getElementById("expected_date");

    startDateInput.addEventListener("change", function() {
        if (this.value) {
            let startDate = new Date(this.value);
            startDate.setDate(startDate.getDate() + 63); // +63 jours
            expectedDateInput.value = startDate.toISOString().split('T')[0];
        }
    });
});
</script>

<%- include('../partials/foot') %>