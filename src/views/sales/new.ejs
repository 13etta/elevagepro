<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<main class="container">
    <h1>Déclarer une transaction</h1>
    <p style="color: #7f8c8d; margin-top:-1rem; margin-bottom: 2rem;">
        Vente définitive d'un animal (sortie de registre) ou réservation d'un chiot.
    </p>

    <form action="/sales" method="POST" class="card form-block">
        
        <div class="form-group" style="margin-bottom: 2rem; padding: 1rem; background: #fdfbf7; border: 1px solid #f39c12; border-radius: 4px;">
            <label style="display: flex; align-items: center; font-weight: bold; color: #d35400;">
                <input type="checkbox" id="is_reservation" name="is_reservation" value="true" style="margin-right: 10px; width: auto;">
                Il s'agit d'une réservation (le chiot ne part pas aujourd'hui)
            </label>
            <div style="margin-top: 1rem;">
                <label for="deposit_amount" style="color: #333;">Montant de l'acompte / arrhes versé ce jour (€)</label>
                <input type="number" step="0.01" id="deposit_amount" name="deposit_amount" value="0.00">
            </div>
        </div>

        <div class="form-group">
            <label for="animal_selection">Sélectionner l'animal *</label>
            <select id="animal_selection" name="animal_selection" required>
                <option value="" data-price="">-- Choisir un animal --</option>
                
                <optgroup id="optgroup-puppies" label="Chiots (Portées actuelles)">
                    <% puppies.forEach(p => { %>
                        <option
                            value="puppy|<%= p.id %>"
                            data-price="<%= p.sale_price || '' %>"
                        >
                            <%= p.name || 'Chiot sans nom' %>
                            <% if (p.mother_name) { %> — portée de <%= p.mother_name %><% } %>
                            (Puce: <%= p.chip_number || 'En attente' %>)
                            <% if (p.sale_price) { %> — <%= p.sale_price %> €<% } %>
                        </option>
                    <% }) %>
                </optgroup>

                <optgroup id="optgroup-dogs" label="Chiens Adultes (Réforme / Replacement)">
                    <% dogs.forEach(d => { %>
                        <option value="dog|<%= d.id %>" data-price=""><%= d.name %> (Puce: <%= d.chip_number || 'N/A' %>)</option>
                    <% }) %>
                </optgroup>

            </select>
            <small style="color: #7f8c8d;">Pour un chiot, le prix renseigné dans sa fiche est repris automatiquement.</small>
        </div>

        <div class="form-group">
            <label for="buyer_name">Nom complet de l'acquéreur *</label>
            <input type="text" id="buyer_name" name="buyer_name" required placeholder="Ex: Jean Dupont">
        </div>

        <div class="form-group">
            <label for="sale_date">Date de la transaction *</label>
            <input type="date" id="sale_date" name="sale_date" required>
        </div>

        <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div class="form-group">
                <label for="price">Montant total de la vente (€) *</label>
                <input type="number" step="0.01" id="price" name="price" required>
            </div>
            <div class="form-group">
                <label for="payment_method">Moyen de paiement</label>
                <select id="payment_method" name="payment_method">
                    <option value="Virement">Virement bancaire</option>
                    <option value="Espèces">Espèces</option>
                    <option value="Chèque">Chèque</option>
                </select>
            </div>
        </div>

        <button type="submit" class="btn btn-primary" style="margin-top: 1rem;">Valider la transaction</button>
    </form>
</main>

<script>
    const reservationCheckbox = document.getElementById('is_reservation');
    const optAdults = document.getElementById('optgroup-dogs');
    const animalSelect = document.getElementById('animal_selection');
    const priceInput = document.getElementById('price');

    function applySelectedAnimalPrice() {
        const selectedOption = animalSelect.options[animalSelect.selectedIndex];
        const selectedPrice = selectedOption ? selectedOption.getAttribute('data-price') : '';

        if (selectedPrice !== null && selectedPrice !== '') {
            priceInput.value = Number(selectedPrice).toFixed(2);
        }
    }

    animalSelect.addEventListener('change', applySelectedAnimalPrice);

    reservationCheckbox.addEventListener('change', function() {
        if (this.checked) {
            optAdults.style.display = 'none';
            if (animalSelect.value.startsWith('dog|')) {
                animalSelect.value = '';
                priceInput.value = '';
            }
        } else {
            optAdults.style.display = 'block';
        }
    });
</script>

<%- include('../partials/foot') %>