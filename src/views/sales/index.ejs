<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<main class="container">
  <h1>Ventes & Comptabilité</h1>

  <section class="kpi-grid" style="margin-bottom: 2rem;">
      <article class="card">
          <h2>Chiffre d'affaires total</h2>
          <strong><%= totalRevenue %> €</strong>
      </article>
      <article class="card">
          <h2>Ventes conclues</h2>
          <strong><%= sales.length %></strong>
      </article>
  </section>

  <section class="table-block">
    <h3>Historique des cessions</h3>
    <table>
      <thead>
        <tr>
            <th>Date</th>
            <th>Chiot</th>
            <th>Acheteur</th>
            <th>Prix</th>
            <th>Méthode</th>
            <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (sales.length === 0) { %>
            <tr><td colspan="6">Aucune vente enregistrée pour le moment.</td></tr>
        <% } %>
        <% sales.forEach((sale) => { %>
          <tr>
            <td><%= new Date(sale.sale_date).toLocaleDateString('fr-FR') %></td>
            <td><strong><%= sale.puppy_name %></strong></td>
            <td><%= sale.buyer_name %></td>
            <td><%= sale.price %> €</td>
            <td><%= sale.payment_method %></td>
            <td>
                <a href="/sales/<%= sale.id %>/pdf" class="btn btn-secondary btn-sm" target="_blank">Générer Attestation (PDF)</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </section>
</main>
<%- include('../partials/foot') %>