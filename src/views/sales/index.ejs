<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<main class="container">
    <div class="header-actions" style="display: flex; justify-content: space-between; align-items: center;">
        <h1>Registre des Ventes</h1>
        <a href="/sales/new" class="btn btn-primary">Déclarer une vente</a>
    </div>
    
    <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem;">
        <span style="color: #7f8c8d;">Chiffre d'affaires totalisé :</span>
        <h2 style="color: var(--accent-color); margin: 0;"><%= totalRevenue %> €</h2>
    </div>

    <section class="card">
        <% if (sales.length === 0) { %>
            <p style="text-align: center; color: #7f8c8d;">Aucune vente enregistrée pour le moment.</p>
        <% } else { %>
            <table class="table" style="width: 100%; text-align: left;">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Chiot</th>
                        <th>Acquéreur</th>
                        <th>Prix</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% sales.forEach(sale => { %>
                        <tr>
                            <td><%= new Date(sale.sale_date).toLocaleDateString('fr-FR') %></td>
                            <td><strong><%= sale.puppy_name %></strong></td>
                            <td><%= sale.buyer_name %></td>
                            <td><%= sale.price %> €</td>
                            <td>
                               <div class="btn-group">
    <a href="/sales/<%= sale.id %>/document/cession" class="btn btn-primary btn-sm" target="_blank" style="margin-right: 5px;">Attestation</a>
    <a href="/sales/<%= sale.id %>/document/facture" class="btn btn-secondary btn-sm" target="_blank">Facture</a>
</div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </section>
</main>
<%- include('../partials/foot') %>