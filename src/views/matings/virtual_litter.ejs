<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container">
    <div class="header-actions">
        <h1>🧬 Simulation : Portée Virtuelle</h1>
        <a href="/matings" class="btn btn-secondary">Retour aux saillies</a>
    </div>

    <form method="GET" action="/matings/virtual-litter" class="card form-grid" style="margin-bottom: 2rem; background-color: #fdfdfd; border-left: 4px solid #f39c12;">
        <div style="display: flex; gap: 1rem; flex-wrap: wrap; width: 100%; align-items: end;">
            <div style="flex: 2;">
                <label style="font-weight: bold; margin-bottom: 0.5rem; display: block;">Étalon (Mâle)</label>
                <select name="male_id" style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;" required>
                    <option value="">-- Choisir un mâle --</option>
                    <% males.forEach(m => { %>
                        <option value="<%= m.id %>" <%= selectedMale && selectedMale.id === m.id ? 'selected' : '' %>><%= m.name %></option>
                    <% }) %>
                </select>
            </div>

            <div style="flex: 2;">
                <label style="font-weight: bold; margin-bottom: 0.5rem; display: block;">Lice (Femelle)</label>
                <select name="female_id" style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;" required>
                    <option value="">-- Choisir une femelle --</option>
                    <% females.forEach(f => { %>
                        <option value="<%= f.id %>" <%= selectedFemale && selectedFemale.id === f.id ? 'selected' : '' %>><%= f.name %></option>
                    <% }) %>
                </select>
            </div>

            <div style="flex: 1;">
                <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.6rem; background-color: #2c3e50;">Générer l'alliance</button>
            </div>
        </div>
    </form>

    <% if (selectedMale && selectedFemale) { %>
        <section class="card" style="padding: 0;">
            <div style="padding: 1.5rem; background-color: #f8f9fa; border-bottom: 1px solid #eee;">
                <h3 style="margin: 0; color: #2c3e50;">Résultat SCC pour <%= selectedMale.name %> × <%= selectedFemale.name %></h3>
            </div>
            
            <div style="padding: 3rem 1.5rem; text-align: center; background-color: #fff;">
                <% if (selectedMale.id_scc && selectedFemale.id_scc) { %>
                    <h4 style="margin-bottom: 1rem; color: #2c3e50;">Lien généré avec succès</h4>
                    <p style="color: #6c757d; margin-bottom: 2rem; max-width: 600px; margin-left: auto; margin-right: auto;">
                        La Centrale Canine bloque l'affichage direct de ses données au sein de logiciels tiers (erreur de connexion). 
                        Clique sur le bouton ci-dessous pour ouvrir la simulation directement et en toute sécurité sur LOF Select.
                    </p>
                    
                    <a href="https://www.centrale-canine.fr/lofselect/alliance-virtuelle/result?chienMaleId=<%= encodeURIComponent(selectedMale.id_scc) %>&chienFemaleId=<%= encodeURIComponent(selectedFemale.id_scc) %>&globalBreedId=223&globalBreedName=Setter%20anglais" 
                       target="_blank" 
                       rel="noopener noreferrer"
                       class="btn btn-primary" 
                       style="padding: 1rem 2rem; font-size: 1.2rem; background-color: #f39c12; border: none; font-weight: bold; color: white; text-decoration: none; display: inline-block;">
                       Ouvrir la simulation SCC (Nouvel onglet)
                    </a>
                    
                <% } else { %>
                    <div style="text-align: center; padding: 2rem; background-color: #fff3cd; color: #856404; border-radius: 4px; max-width: 600px; margin: 0 auto;">
                        <span style="font-size: 2rem;">⚠️</span><br><br>
                        <strong>Impossible de générer le lien vers la SCC.</strong><br>
                        Assure-toi que les deux reproducteurs possèdent un identifiant SCC valide dans leur fiche (Module Mes Chiens).
                    </div>
                <% } %>
            </div>
        </section>
    <% } %>

</main>

<%- include('../partials/foot') %>