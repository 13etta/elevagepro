<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container">
    <div class="header-actions">
        <h1>Modifier la saillie</h1>
        <div class="actions">
            <a href="/matings" class="btn btn-secondary">Annuler et retour</a>
        </div>
    </div>

    <form action="/matings/<%= mating.id %>/edit" method="POST" class="card form-block">
        <h3 style="color: var(--primary-color); border-bottom: 1px solid #eee; padding-bottom: 0.5rem; margin-bottom: 1.5rem;">Reproducteurs</h3>
        
        <div class="form-grid">
            <div class="form-group">
                <label for="male_id">Étalon (Mâle) *</label>
                <select id="male_id" name="male_id" required>
                    <% males.forEach(m => { %>
                        <option value="<%= m.id %>" <%= mating.male_id === m.id ? 'selected' : '' %>><%= m.name %></option>
                    <% }) %>
                </select>
            </div>
            <div class="form-group">
                <label for="female_id">Lice (Femelle) *</label>
                <select id="female_id" name="female_id" required>
                    <% females.forEach(f => { %>
                        <option value="<%= f.id %>" <%= mating.female_id === f.id ? 'selected' : '' %>><%= f.name %></option>
                    <% }) %>
                </select>
            </div>
        </div>

        <h3 style="color: var(--primary-color); border-bottom: 1px solid #eee; padding-bottom: 0.5rem; margin-top: 2rem; margin-bottom: 1.5rem;">Détails de l'acte</h3>
        
        <div class="form-grid">
            <div class="form-group">
                <label for="mating_date">Date de la saillie *</label>
                <input type="date" id="mating_date" name="mating_date" 
                       value="<%= mating.mating_date ? new Date(mating.mating_date).toISOString().split('T')[0] : '' %>" required>
            </div>
            <div class="form-group">
                <label for="method">Méthode</label>
                <select id="method" name="method">
                    <option value="Naturelle" <%= mating.method === 'Naturelle' ? 'selected' : '' %>>Naturelle</option>
                    <option value="Insémination" <%= mating.method === 'Insémination' ? 'selected' : '' %>>Insémination (IA)</option>
                </select>
            </div>
        </div>

        <div class="form-group" style="margin-top: 1rem;">
            <label for="place">Lieu de la saillie</label>
            <input type="text" id="place" name="place" value="<%= mating.place || '' %>" placeholder="Ex: Chez l'étalonnier, Clinique vétérinaire...">
        </div>

        <div class="form-group" style="margin-top: 1rem;">
            <label for="notes">Observations (Comportement, verrouillage...)</label>
            <textarea id="notes" name="notes" rows="4"><%= mating.notes || '' %></textarea>
        </div>

        <div style="margin-top: 3rem; padding-top: 2rem; border-top: 2px solid #eee;">
            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1.2rem; font-size: 1.2rem; font-weight: bold;">
                💾 Enregistrer les modifications
            </button>
        </div>
    </form>
</main>

<%- include('../partials/foot') %>