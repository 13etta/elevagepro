<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<style>
  .settings-tabs { display:flex; gap:12px; margin: 0 0 20px; flex-wrap:wrap; }
  .settings-tab { border:1px solid var(--border-color); background:var(--surface); color:var(--text-color); border-radius:999px; padding:10px 16px; font-weight:900; text-decoration:none; }
  .settings-tab.active { background:var(--primary-color); color:#08111f; }
  .settings-panel { display:none; }
  .settings-panel.active { display:block; }
  .settings-builder-grid { display:grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap:18px; align-items:start; }
  .settings-builder-card { box-shadow:none; background:var(--surface-2); border:1px solid var(--border-color); }
  .template-grid { display:grid; grid-template-columns: repeat(5, minmax(0,1fr)); gap:12px; }
  .template-option { border:1px solid var(--border-color); border-radius:18px; padding:12px; background:var(--surface); cursor:pointer; min-height:120px; }
  .template-option input { margin-right:8px; }
  .template-preview { height:58px; border-radius:12px; margin:10px 0; border:1px solid rgba(255,255,255,.12); }
  .template-heritage { background:linear-gradient(135deg,#f6f1e8,#c8b397); }
  .template-field { background:linear-gradient(135deg,#23311f,#8a6a37); }
  .template-luxury { background:linear-gradient(135deg,#111827,#b45309); }
  .template-minimal { background:linear-gradient(135deg,#ffffff,#e5e7eb); }
  .template-breeder { background:linear-gradient(135deg,#172554,#93c5fd); }
  .color-grid { display:grid; grid-template-columns: repeat(5, minmax(0,1fr)); gap:12px; }
  .switch-grid { display:grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap:10px; }
  .switch-pill { border:1px solid var(--border-color); border-radius:14px; padding:10px; background:var(--surface); font-weight:800; }
  .media-strip { display:grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap:10px; margin-top:10px; }
  .media-tile { position:relative; border:1px solid var(--border-color); border-radius:16px; overflow:hidden; background:var(--surface); min-height:92px; }
  .media-tile img { width:100%; height:92px; object-fit:cover; display:block; }
  .media-tile label { display:block; padding:8px; font-size:.78rem; }
  .litter-media { border:1px solid var(--border-color); border-radius:16px; padding:12px; margin-top:12px; background:var(--surface); }
  @media (max-width: 1000px) { .settings-builder-grid, .template-grid, .color-grid, .switch-grid, .media-strip { grid-template-columns:1fr; } }
</style>

<main class="container">
  <section class="page-hero">
    <div>
      <p class="eyebrow"><%= __('settings.title') %></p>
      <h1>Paramètres</h1>
      <p>Configurez séparément l’application métier ElevagePro et le site vitrine généré automatiquement.</p>
    </div>
    <% if (typeof publicSiteUrl !== 'undefined') { %>
      <a class="btn btn-secondary" href="<%= publicSiteUrl %>" target="_blank">Voir la vitrine</a>
    <% } %>
  </section>

  <nav class="settings-tabs" aria-label="Onglets paramètres">
    <a href="?tab=application" class="settings-tab" data-tab-link="application">Application</a>
    <a href="?tab=vitrine" class="settings-tab" data-tab-link="vitrine">Site vitrine</a>
  </nav>

  <section id="settings-application" class="settings-panel" data-tab-panel="application">
    <section class="settings-grid">
      <article class="card settings-card">
        <div class="section-title">
          <span class="section-kicker">Application</span>
          <h2>Identité de l’élevage</h2>
        </div>

        <form action="/settings" method="POST" class="stacked-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="form-group"><label for="company_name">Nom public / société</label><input type="text" id="company_name" name="company_name" value="<%= breeder.company_name || breeder.name || '' %>" required></div>
          <div class="form-group"><label for="affix_name">Affixe</label><input type="text" id="affix_name" name="affix_name" value="<%= breeder.affix_name || '' %>"></div>
          <div class="form-grid">
            <div class="form-group"><label for="siret">SIRET</label><input type="text" id="siret" name="siret" value="<%= breeder.siret || '' %>"></div>
            <div class="form-group"><label for="producer_number">N° producteur</label><input type="text" id="producer_number" name="producer_number" value="<%= breeder.producer_number || '' %>"></div>
          </div>
          <div class="form-group"><label for="address">Adresse</label><textarea id="address" name="address" rows="4"><%= breeder.address || '' %></textarea></div>
          <button type="submit" class="btn btn-primary">Enregistrer l’identité</button>
        </form>
      </article>

      <article class="card settings-card">
        <div class="section-title">
          <span class="section-kicker">Interface</span>
          <h2>Préférences ElevagePro</h2>
        </div>
        <form action="/settings/preferences" method="POST" class="stacked-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="form-group"><label for="lang">Langue</label><select id="lang" name="lang"><option value="fr" <%= currentLang === 'fr' ? 'selected' : '' %>>Français</option><option value="en" <%= currentLang === 'en' ? 'selected' : '' %>>English</option></select></div>
          <div class="form-group"><label for="theme">Thème application</label><select id="theme" name="theme"><option value="prestige" <%= theme === 'prestige' ? 'selected' : '' %>><%= __('themes.prestige') %></option><option value="clinical" <%= theme === 'clinical' ? 'selected' : '' %>><%= __('themes.clinical') %></option><option value="nature" <%= theme === 'nature' ? 'selected' : '' %>><%= __('themes.nature') %></option></select></div>
          <button type="submit" class="btn btn-primary">Enregistrer l’application</button>
        </form>
      </article>

      <article class="card settings-card settings-logo-card">
        <div class="section-title"><span class="section-kicker">Logo ERP</span><h2>Logo de l’application</h2></div>
        <% if (breeder.logo_url || breeder.logo) { %><div class="logo-preview"><img src="<%= breeder.logo_url || breeder.logo %>" alt="Logo"></div><% } else { %><div class="empty-logo-preview"><strong>EP</strong><p>Aucun logo configuré</p></div><% } %>
        <form action="/settings/logo" method="POST" enctype="multipart/form-data" class="stacked-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="form-group"><label for="logo">Remplacer le logo</label><input type="file" id="logo" name="logo" accept="image/png, image/jpeg, image/webp" required></div>
          <button type="submit" class="btn btn-secondary">Uploader le logo</button>
        </form>
      </article>
    </section>
  </section>

  <section id="settings-vitrine" class="settings-panel" data-tab-panel="vitrine">
    <form action="/settings/website" method="POST" enctype="multipart/form-data" class="stacked-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <article class="card settings-card">
        <div class="section-title"><span class="section-kicker">Générateur de site</span><h2>Choisir un template</h2><p class="muted">Le template modifie la structure visuelle de la vitrine, sans toucher aux données métier.</p></div>
        <div class="template-grid">
          <% const labels = { heritage:'Tradition', field:'Chasse & field', luxury:'Premium sombre', minimal:'Minimal clair', breeder:'Catalogue élevage' }; %>
          <% (websiteTemplates || ['heritage','field','luxury','minimal','breeder']).forEach((tpl) => { %>
            <label class="template-option">
              <input type="radio" name="template" value="<%= tpl %>" <%= websiteSettings.template === tpl ? 'checked' : '' %>> <strong><%= labels[tpl] || tpl %></strong>
              <div class="template-preview template-<%= tpl %>"></div>
              <small><%= tpl %></small>
            </label>
          <% }) %>
        </div>
      </article>

      <section class="settings-builder-grid">
        <article class="card settings-builder-card">
          <div class="section-title compact"><span class="section-kicker">Accueil</span><h3>Hero et introduction</h3></div>
          <div class="form-group"><label for="heroTitle">Titre principal</label><input id="heroTitle" name="heroTitle" value="<%= websiteSettings.heroTitle || '' %>"></div>
          <div class="form-group"><label for="heroSubtitle">Sous-titre</label><textarea id="heroSubtitle" name="heroSubtitle" rows="3"><%= websiteSettings.heroSubtitle || '' %></textarea></div>
          <div class="form-group"><label for="introTitle">Titre d’introduction</label><input id="introTitle" name="introTitle" value="<%= websiteSettings.introTitle || '' %>"></div>
          <div class="form-group"><label for="introText">Texte d’introduction</label><textarea id="introText" name="introText" rows="4"><%= websiteSettings.introText || '' %></textarea></div>
          <% if (websiteSettings.heroImageUrl) { %><div class="media-tile"><img src="<%= websiteSettings.heroImageUrl %>" alt="Hero"><label><input type="checkbox" name="clearHeroImage"> Supprimer l’image d’accueil</label></div><% } %>
          <div class="form-group"><label for="hero_image">Ajouter / remplacer l’image d’accueil</label><input type="file" id="hero_image" name="hero_image" accept="image/png, image/jpeg, image/webp"></div>
        </article>

        <article class="card settings-builder-card">
          <div class="section-title compact"><span class="section-kicker">Design</span><h3>Couleurs complètes</h3></div>
          <div class="color-grid">
            <div class="form-group"><label>Principale</label><input type="color" name="primaryColor" value="<%= websiteSettings.primaryColor || '#6d7c45' %>"></div>
            <div class="form-group"><label>Secondaire</label><input type="color" name="secondaryColor" value="<%= websiteSettings.secondaryColor || '#c8b397' %>"></div>
            <div class="form-group"><label>Accent</label><input type="color" name="accentColor" value="<%= websiteSettings.accentColor || '#2b2014' %>"></div>
            <div class="form-group"><label>Fond</label><input type="color" name="backgroundColor" value="<%= websiteSettings.backgroundColor || '#f6f1e8' %>"></div>
            <div class="form-group"><label>Texte</label><input type="color" name="textColor" value="<%= websiteSettings.textColor || '#2b2014' %>"></div>
          </div>
          <div class="section-title compact"><span class="section-kicker">Sections</span><h3>Afficher / masquer</h3></div>
          <div class="switch-grid">
            <label class="switch-pill"><input type="checkbox" name="showIntro" <%= websiteSettings.showIntro ? 'checked' : '' %>> Intro</label>
            <label class="switch-pill"><input type="checkbox" name="showPuppies" <%= websiteSettings.showPuppies ? 'checked' : '' %>> Chiots</label>
            <label class="switch-pill"><input type="checkbox" name="showLitters" <%= websiteSettings.showLitters ? 'checked' : '' %>> Portées</label>
            <label class="switch-pill"><input type="checkbox" name="showDogs" <%= websiteSettings.showDogs ? 'checked' : '' %>> Chiens</label>
            <label class="switch-pill"><input type="checkbox" name="showServices" <%= websiteSettings.showServices ? 'checked' : '' %>> Services</label>
            <label class="switch-pill"><input type="checkbox" name="showGallery" <%= websiteSettings.showGallery ? 'checked' : '' %>> Galerie</label>
            <label class="switch-pill"><input type="checkbox" name="showContact" <%= websiteSettings.showContact ? 'checked' : '' %>> Contact</label>
          </div>
        </article>
      </section>

      <section class="settings-builder-grid">
        <article class="card settings-builder-card">
          <div class="section-title compact"><span class="section-kicker">Services</span><h3>Blocs personnalisables</h3></div>
          <div class="form-group"><label>Service 1</label><input name="service1Title" value="<%= websiteSettings.service1Title || '' %>"><textarea name="service1Text" rows="2"><%= websiteSettings.service1Text || '' %></textarea></div>
          <div class="form-group"><label>Service 2</label><input name="service2Title" value="<%= websiteSettings.service2Title || '' %>"><textarea name="service2Text" rows="2"><%= websiteSettings.service2Text || '' %></textarea></div>
          <div class="form-group"><label>Service 3</label><input name="service3Title" value="<%= websiteSettings.service3Title || '' %>"><textarea name="service3Text" rows="2"><%= websiteSettings.service3Text || '' %></textarea></div>
        </article>
        <article class="card settings-builder-card">
          <div class="section-title compact"><span class="section-kicker">Contact public</span><h3>Coordonnées et réseaux</h3></div>
          <div class="form-group"><label>Titre actualité</label><input name="newsTitle" value="<%= websiteSettings.newsTitle || '' %>"></div>
          <div class="form-group"><label>Texte actualité</label><textarea name="newsText" rows="3"><%= websiteSettings.newsText || '' %></textarea></div>
          <div class="form-group"><label>Points forts — un par ligne</label><textarea name="strengths" rows="4"><%= websiteSettings.strengths || '' %></textarea></div>
          <div class="form-grid"><div class="form-group"><label>Téléphone</label><input name="phone" value="<%= websiteSettings.phone || '' %>"></div><div class="form-group"><label>Email public</label><input name="publicEmail" value="<%= websiteSettings.publicEmail || '' %>"></div><div class="form-group"><label>Instagram</label><input name="instagram" value="<%= websiteSettings.instagram || '' %>"></div><div class="form-group"><label>Facebook</label><input name="facebook" value="<%= websiteSettings.facebook || '' %>"></div></div>
        </article>
      </section>

      <article class="card settings-card">
        <div class="section-title"><span class="section-kicker">Photothèque</span><h2>Galerie globale</h2></div>
        <div class="form-group"><label for="gallery_images">Ajouter des photos au site</label><input type="file" id="gallery_images" name="gallery_images" accept="image/png, image/jpeg, image/webp" multiple></div>
        <% if (websiteSettings.gallery && websiteSettings.gallery.length) { %><div class="media-strip"><% websiteSettings.gallery.forEach((image) => { %><div class="media-tile"><img src="<%= image.url %>" alt="Photo"><label><input type="checkbox" name="removeGallery" value="<%= image.url %>"> Supprimer</label></div><% }) %></div><% } %>
      </article>

      <article class="card settings-card">
        <div class="section-title"><span class="section-kicker">Portées</span><h2>Photos par portée</h2><p class="muted">Chaque portée peut avoir ses propres photos publiques.</p></div>
        <% if (!litters || !litters.length) { %><p class="muted">Aucune portée disponible pour le moment.</p><% } %>
        <% (litters || []).forEach((litter) => { const imgs = (websiteSettings.litterGallery && websiteSettings.litterGallery[litter.id]) || []; %>
          <div class="litter-media">
            <strong>Portée <%= litter.mother_name || 'mère non renseignée' %> — <%= formatDate(litter.birth_date) %></strong>
            <div class="form-group"><label>Ajouter des photos pour cette portée</label><input type="file" name="litter_images_<%= litter.id %>" accept="image/png, image/jpeg, image/webp" multiple></div>
            <% if (imgs.length) { %><div class="media-strip"><% imgs.forEach((image) => { %><div class="media-tile"><img src="<%= image.url %>" alt="Portée"><label><input type="checkbox" name="removeLitterImage" value="<%= image.url %>"> Supprimer</label></div><% }) %></div><% } %>
          </div>
        <% }) %>
      </article>

      <button type="submit" class="btn btn-primary">Enregistrer et générer la vitrine</button>
    </form>
  </section>
</main>

<script>
  const params = new URLSearchParams(window.location.search);
  const active = params.get('tab') || 'application';
  document.querySelectorAll('[data-tab-link]').forEach((link) => link.classList.toggle('active', link.dataset.tabLink === active));
  document.querySelectorAll('[data-tab-panel]').forEach((panel) => panel.classList.toggle('active', panel.dataset.tabPanel === active));
</script>

<%- include('../partials/foot') %>
