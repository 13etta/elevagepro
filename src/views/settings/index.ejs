<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container settings-builder-page">
  <section class="page-hero">
    <div>
      <p class="eyebrow"><%= __('settings.title') %></p>
      <h1>Centre de réglage ElevagePro</h1>
      <p>Un espace pour séparer clairement les paramètres internes de l’application et le générateur de site vitrine public.</p>
    </div>
    <% if (typeof publicSiteUrl !== 'undefined') { %>
      <a class="btn btn-secondary" href="<%= publicSiteUrl %>" target="_blank">Voir la vitrine</a>
    <% } %>
  </section>

  <nav class="settings-tabs" aria-label="Onglets paramètres">
    <a class="settings-tab <%= activeSettingsTab === 'application' ? 'active' : '' %>" href="/settings?tab=application">Application</a>
    <a class="settings-tab <%= activeSettingsTab === 'vitrine' ? 'active' : '' %>" href="/settings?tab=vitrine">Site vitrine</a>
  </nav>

  <% if (activeSettingsTab === 'application') { %>
    <section class="settings-grid">
      <article class="card settings-card">
        <div class="section-title">
          <span class="section-kicker">Application</span>
          <h2>Identité de l’élevage</h2>
          <p class="muted">Ces informations alimentent ElevagePro et peuvent aussi être reprises par la vitrine.</p>
        </div>

        <form action="/settings" method="POST" class="stacked-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="form-group">
            <label for="company_name"><%= __('settings.companyName') %></label>
            <input type="text" id="company_name" name="company_name" value="<%= breeder.company_name || breeder.name || '' %>" required>
          </div>

          <div class="form-group">
            <label for="affix_name"><%= __('settings.affixName') %></label>
            <input type="text" id="affix_name" name="affix_name" value="<%= breeder.affix_name || '' %>">
          </div>

          <div class="form-grid">
            <div class="form-group">
              <label for="siret"><%= __('settings.siret') %></label>
              <input type="text" id="siret" name="siret" value="<%= breeder.siret || '' %>">
            </div>
            <div class="form-group">
              <label for="producer_number">N° producteur</label>
              <input type="text" id="producer_number" name="producer_number" value="<%= breeder.producer_number || '' %>">
            </div>
          </div>

          <div class="form-group">
            <label for="address"><%= __('settings.address') %></label>
            <textarea id="address" name="address" rows="4"><%= breeder.address || '' %></textarea>
          </div>

          <button type="submit" class="btn btn-primary"><%= __('settings.saveIdentity') %></button>
        </form>
      </article>

      <article class="card settings-card">
        <div class="section-title">
          <span class="section-kicker"><%= __('settings.appearance') %></span>
          <h2>Préférences internes</h2>
          <p class="muted">Ces réglages ne concernent que l’interface de gestion ElevagePro.</p>
        </div>

        <form action="/settings/preferences" method="POST" class="stacked-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="form-group">
            <label for="lang"><%= __('settings.language') %></label>
            <select id="lang" name="lang">
              <option value="fr" <%= currentLang === 'fr' ? 'selected' : '' %>>Français</option>
              <option value="en" <%= currentLang === 'en' ? 'selected' : '' %>>English</option>
            </select>
          </div>

          <div class="form-group">
            <label for="theme"><%= __('settings.theme') %></label>
            <select id="theme" name="theme">
              <option value="prestige" <%= theme === 'prestige' ? 'selected' : '' %>><%= __('themes.prestige') %></option>
              <option value="clinical" <%= theme === 'clinical' ? 'selected' : '' %>><%= __('themes.clinical') %></option>
              <option value="nature" <%= theme === 'nature' ? 'selected' : '' %>><%= __('themes.nature') %></option>
            </select>
          </div>

          <div class="theme-preview-grid">
            <div class="theme-preview prestige"><span></span><strong><%= __('themes.prestige') %></strong></div>
            <div class="theme-preview clinical"><span></span><strong><%= __('themes.clinical') %></strong></div>
            <div class="theme-preview nature"><span></span><strong><%= __('themes.nature') %></strong></div>
          </div>

          <button type="submit" class="btn btn-primary"><%= __('settings.savePreferences') %></button>
        </form>
      </article>

      <article class="card settings-card settings-logo-card">
        <div class="section-title">
          <span class="section-kicker"><%= __('settings.visualIdentity') %></span>
          <h2><%= __('settings.logo') %></h2>
        </div>

        <% if (breeder.logo_url || breeder.logo) { %>
          <div class="logo-preview">
            <img src="<%= breeder.logo_url || breeder.logo %>" alt="<%= __('settings.logo') %>">
          </div>
        <% } else { %>
          <div class="empty-logo-preview">
            <strong>EP</strong>
            <p><%= __('settings.noLogo') %></p>
          </div>
        <% } %>

        <form action="/settings/logo" method="POST" enctype="multipart/form-data" class="stacked-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="form-group">
            <label for="logo"><%= __('settings.chooseLogo') %></label>
            <input type="file" id="logo" name="logo" accept="image/png, image/jpeg, image/webp" required>
          </div>
          <button type="submit" class="btn btn-secondary"><%= __('settings.uploadLogo') %></button>
        </form>
      </article>
    </section>
  <% } %>

  <% if (activeSettingsTab === 'vitrine') { %>
    <section class="card settings-card settings-logo-card">
      <div class="section-title">
        <span class="section-kicker">Site vitrine</span>
        <h2>Générateur de site public</h2>
        <p class="muted">Choisissez un template, personnalisez les couleurs, les textes, les images et les photos associées aux portées.</p>
      </div>

      <form action="/settings/website" method="POST" enctype="multipart/form-data" class="stacked-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="settings-panel">
          <div class="section-title compact">
            <span class="section-kicker">Template</span>
            <h3>Choix graphique</h3>
          </div>
          <div class="template-picker">
            <% const templateLabels = { heritage: 'Héritage', field: 'Field & chasse', luxury: 'Premium sombre', minimal: 'Minimal moderne', breeder: 'Catalogue élevage' }; %>
            <% websiteTemplates.forEach((tpl) => { %>
              <label class="template-option <%= websiteSettings.template === tpl ? 'selected' : '' %>">
                <input type="radio" name="template" value="<%= tpl %>" <%= websiteSettings.template === tpl ? 'checked' : '' %>>
                <strong><%= templateLabels[tpl] || tpl %></strong>
                <span><%= tpl %></span>
              </label>
            <% }) %>
          </div>
        </div>

        <div class="dashboard-columns">
          <div class="card" style="box-shadow:none; background:var(--surface-2);">
            <div class="section-title compact">
              <span class="section-kicker">Accueil</span>
              <h3>Hero de page</h3>
            </div>
            <div class="form-group">
              <label for="heroTitle">Titre principal</label>
              <input type="text" id="heroTitle" name="heroTitle" value="<%= websiteSettings.heroTitle || '' %>">
            </div>
            <div class="form-group">
              <label for="heroSubtitle">Texte d’introduction</label>
              <textarea id="heroSubtitle" name="heroSubtitle" rows="4"><%= websiteSettings.heroSubtitle || '' %></textarea>
            </div>
            <% if (websiteSettings.heroImageUrl) { %>
              <div class="mini-gallery"><img src="<%= websiteSettings.heroImageUrl %>" alt="Image d’accueil"></div>
              <label><input type="checkbox" name="clearHeroImage"> Supprimer l’image d’accueil</label>
            <% } %>
            <div class="form-group">
              <label for="hero_image">Remplacer / ajouter l’image d’accueil</label>
              <input type="file" id="hero_image" name="hero_image" accept="image/png, image/jpeg, image/webp">
            </div>
          </div>

          <div class="card" style="box-shadow:none; background:var(--surface-2);">
            <div class="section-title compact">
              <span class="section-kicker">Couleurs</span>
              <h3>Palette complète</h3>
            </div>
            <div class="form-grid">
              <div class="form-group"><label>Principale</label><input type="color" name="primaryColor" value="<%= websiteSettings.primaryColor || '#6d7c45' %>"></div>
              <div class="form-group"><label>Secondaire</label><input type="color" name="secondaryColor" value="<%= websiteSettings.secondaryColor || '#c8b397' %>"></div>
              <div class="form-group"><label>Accent</label><input type="color" name="accentColor" value="<%= websiteSettings.accentColor || '#2b2014' %>"></div>
              <div class="form-group"><label>Fond</label><input type="color" name="backgroundColor" value="<%= websiteSettings.backgroundColor || '#f6f1e8' %>"></div>
              <div class="form-group"><label>Texte</label><input type="color" name="textColor" value="<%= websiteSettings.textColor || '#2b2014' %>"></div>
            </div>
          </div>
        </div>

        <div class="dashboard-columns">
          <div class="card" style="box-shadow:none; background:var(--surface-2);">
            <div class="section-title compact"><span class="section-kicker">Sections</span><h3>Afficher / masquer</h3></div>
            <label><input type="checkbox" name="showIntro" <%= websiteSettings.showIntro ? 'checked' : '' %>> Introduction</label><br>
            <label><input type="checkbox" name="showPuppies" <%= websiteSettings.showPuppies ? 'checked' : '' %>> Chiots</label><br>
            <label><input type="checkbox" name="showLitters" <%= websiteSettings.showLitters ? 'checked' : '' %>> Portées</label><br>
            <label><input type="checkbox" name="showDogs" <%= websiteSettings.showDogs ? 'checked' : '' %>> Chiens</label><br>
            <label><input type="checkbox" name="showServices" <%= websiteSettings.showServices ? 'checked' : '' %>> Services</label><br>
            <label><input type="checkbox" name="showGallery" <%= websiteSettings.showGallery ? 'checked' : '' %>> Galerie</label><br>
            <label><input type="checkbox" name="showContact" <%= websiteSettings.showContact ? 'checked' : '' %>> Contact</label>
          </div>

          <div class="card" style="box-shadow:none; background:var(--surface-2);">
            <div class="section-title compact"><span class="section-kicker">Introduction</span><h3>Texte éditorial</h3></div>
            <div class="form-group"><label>Titre introduction</label><input name="introTitle" value="<%= websiteSettings.introTitle || '' %>"></div>
            <div class="form-group"><label>Texte introduction</label><textarea name="introText" rows="5"><%= websiteSettings.introText || '' %></textarea></div>
          </div>
        </div>

        <div class="dashboard-columns">
          <div class="card" style="box-shadow:none; background:var(--surface-2);">
            <div class="section-title compact"><span class="section-kicker">Services</span><h3>Blocs métier</h3></div>
            <div class="form-group"><label>Service 1</label><input name="service1Title" value="<%= websiteSettings.service1Title || '' %>"><textarea name="service1Text" rows="2"><%= websiteSettings.service1Text || '' %></textarea></div>
            <div class="form-group"><label>Service 2</label><input name="service2Title" value="<%= websiteSettings.service2Title || '' %>"><textarea name="service2Text" rows="2"><%= websiteSettings.service2Text || '' %></textarea></div>
            <div class="form-group"><label>Service 3</label><input name="service3Title" value="<%= websiteSettings.service3Title || '' %>"><textarea name="service3Text" rows="2"><%= websiteSettings.service3Text || '' %></textarea></div>
          </div>

          <div class="card" style="box-shadow:none; background:var(--surface-2);">
            <div class="section-title compact"><span class="section-kicker">Actualités & contact</span><h3>Textes publics</h3></div>
            <div class="form-group"><label>Titre actualité</label><input name="newsTitle" value="<%= websiteSettings.newsTitle || '' %>"></div>
            <div class="form-group"><label>Texte actualité</label><textarea name="newsText" rows="3"><%= websiteSettings.newsText || '' %></textarea></div>
            <div class="form-group"><label>Points forts — un par ligne</label><textarea name="strengths" rows="5"><%= websiteSettings.strengths || '' %></textarea></div>
            <div class="form-grid">
              <div class="form-group"><label>Téléphone</label><input name="phone" value="<%= websiteSettings.phone || '' %>"></div>
              <div class="form-group"><label>Email public</label><input name="publicEmail" value="<%= websiteSettings.publicEmail || '' %>"></div>
              <div class="form-group"><label>Instagram</label><input name="instagram" value="<%= websiteSettings.instagram || '' %>"></div>
              <div class="form-group"><label>Facebook</label><input name="facebook" value="<%= websiteSettings.facebook || '' %>"></div>
            </div>
          </div>
        </div>

        <div class="settings-panel">
          <div class="section-title compact"><span class="section-kicker">Galerie</span><h3>Photos générales du site</h3></div>
          <div class="form-group"><label>Ajouter des photos</label><input type="file" name="gallery_images" accept="image/png, image/jpeg, image/webp" multiple></div>
          <% if (websiteSettings.gallery && websiteSettings.gallery.length) { %>
            <div class="image-manage-grid">
              <% websiteSettings.gallery.forEach((image) => { %>
                <label class="image-manage-card">
                  <img src="<%= image.url %>" alt="Photo vitrine">
                  <span><input type="checkbox" name="removeGallery" value="<%= image.url %>"> Supprimer</span>
                </label>
              <% }) %>
            </div>
          <% } %>
        </div>

        <div class="settings-panel">
          <div class="section-title compact"><span class="section-kicker">Portées</span><h3>Photos par portée</h3></div>
          <% if (!litters.length) { %>
            <p class="muted">Aucune portée à enrichir pour le moment.</p>
          <% } %>
          <% litters.forEach((litter) => { const litterImages = (websiteSettings.litterGallery && websiteSettings.litterGallery[litter.id]) || []; %>
            <article class="litter-photo-settings">
              <div>
                <strong>Portée de <%= litter.mother_name || 'mère non renseignée' %></strong>
                <p class="muted">Naissance : <%= formatDate(litter.birth_date) %> — <%= litter.puppies_count || litter.nb_puppies || 0 %> chiot(s)</p>
              </div>
              <div class="form-group"><label>Ajouter des photos pour cette portée</label><input type="file" name="litter_images_<%= litter.id %>" accept="image/png, image/jpeg, image/webp" multiple></div>
              <% if (litterImages.length) { %>
                <div class="image-manage-grid">
                  <% litterImages.forEach((image) => { %>
                    <label class="image-manage-card">
                      <img src="<%= image.url %>" alt="Photo portée">
                      <span><input type="checkbox" name="removeLitterImage" value="<%= image.url %>"> Supprimer</span>
                    </label>
                  <% }) %>
                </div>
              <% } %>
            </article>
          <% }) %>
        </div>

        <button type="submit" class="btn btn-primary">Enregistrer le site vitrine</button>
      </form>
    </section>
  <% } %>
</main>

<%- include('../partials/foot') %>
