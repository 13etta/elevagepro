<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <meta name="description" content="<%= websiteSettings.heroSubtitle || 'Élevage canin familial, sélection, passion et accompagnement.' %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@700;900&family=Merriweather+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/phase5.css">
  <link rel="stylesheet" href="/css/showcase-heritage.css">
</head>
<%
  const siteTitle = breeder.company_name || breeder.name || 'Élevage canin';
  const logoUrl = breeder.logo_url || breeder.logo || '';
  const strengthsList = String(websiteSettings.strengths || '')
    .split(/\r?\n/)
    .map((item) => item.trim())
    .filter(Boolean);
  const trialUrl = '/auth/register';
%>
<body
  data-theme="nature"
  class="public-website-body showcase-template-<%= websiteSettings.template || 'heritage' %>"
  style="--showcase-primary:<%= websiteSettings.primaryColor %>;--showcase-secondary:<%= websiteSettings.secondaryColor %>;--showcase-accent:<%= websiteSettings.accentColor || '#2b2014' %>;--showcase-bg:<%= websiteSettings.backgroundColor || '#f6f1e8' %>;--showcase-text:<%= websiteSettings.textColor || '#2b2014' %>;"
>
  <main class="public-site premium-showcase">
    <header class="institutional-header">
      <div class="institutional-logo-block">
        <% if (logoUrl) { %>
          <img src="<%= logoUrl %>" alt="Logo <%= siteTitle %>">
        <% } else { %>
          <span class="institutional-logo-fallback"><%= String(siteTitle).slice(0, 1) %></span>
        <% } %>
        <div>
          <strong><%= siteTitle %></strong>
          <% if (breeder.affix_name) { %><small><%= breeder.affix_name %></small><% } %>
        </div>
      </div>
      <div class="institutional-info-block">
        <p class="institutional-slogan"><%= websiteSettings.siteSlogan || websiteSettings.heroSubtitle || 'Élevage canin familial, sélection et accompagnement.' %></p>
        <% if (breeder.address) { %><p class="institutional-address"><%= breeder.address %></p><% } %>
        <% if (websiteSettings.openingHours) { %><p class="institutional-hours"><%= websiteSettings.openingHours %></p><% } %>
        <% if (websiteSettings.phone) { %><p class="institutional-phone"><a href="tel:<%= websiteSettings.phone %>"><%= websiteSettings.phone %></a></p><% } %>
      </div>
    </header>

    <nav class="showcase-nav" aria-label="Navigation vitrine">
      <a href="#accueil" class="showcase-brand">
        <% if (logoUrl) { %>
          <img src="<%= logoUrl %>" alt="Logo <%= siteTitle %>">
        <% } else { %>
          <span><%= String(siteTitle).slice(0, 1) %></span>
        <% } %>
        <strong><%= siteTitle %></strong>
      </a>
      <div class="showcase-links">
        <a href="#accueil">Accueil</a>
        <% if (websiteSettings.showServices) { %><a href="#services">Services</a><% } %>
        <% if (websiteSettings.showDogs) { %><a href="#selection">Sélection</a><% } %>
        <% if (websiteSettings.showPuppies) { %><a href="#chiots">Chiots</a><% } %>
        <a href="#temoignages">Témoignages</a>
        <% if (websiteSettings.showGallery) { %><a href="#galerie">Galerie</a><% } %>
        <% if (websiteSettings.showContact) { %><a href="#contact">Contact</a><% } %>
        <a class="showcase-nav-cta" href="<%= trialUrl %>">Créer mon élevage</a>
      </div>
    </nav>

    <section class="contact-strip">
      <div>
        <strong><%= websiteSettings.contactStripTitle || 'Besoin d’un renseignement ?' %></strong>
        <span><%= websiteSettings.contactStripText || 'Informations, réservation, projet de portée ou disponibilité.' %></span>
      </div>
      <div class="contact-strip-actions">
        <a class="showcase-btn primary" href="<%= trialUrl %>">Essayer gratuitement</a>
        <% if (websiteSettings.showContact) { %><a class="showcase-btn secondary" href="#contact"><%= websiteSettings.primaryCtaLabel || 'Contactez-nous' %></a><% } %>
      </div>
    </section>

    <section id="accueil" class="public-hero premium-hero">
      <div class="premium-hero-copy">
        <p class="eyebrow">Élevage canin · Sélection raisonnée</p>
        <h1><%= websiteSettings.heroTitle || siteTitle %></h1>
        <% if (breeder.affix_name) { %><p class="public-affix"><%= breeder.affix_name %></p><% } %>
        <p class="hero-lead"><%= websiteSettings.heroSubtitle || 'Une vitrine claire pour présenter la sélection, les reproducteurs, les portées et la philosophie de l’élevage.' %></p>
        <div class="hero-actions">
          <a class="showcase-btn primary" href="<%= trialUrl %>">Créer mon élevage</a>
          <% if (websiteSettings.showPuppies) { %><a class="showcase-btn secondary" href="#chiots">Voir les disponibilités</a><% } %>
          <% if (websiteSettings.showContact) { %><a class="showcase-btn secondary" href="#contact">Contacter l’élevage</a><% } %>
        </div>
      </div>
      <aside class="hero-portrait" <% if (websiteSettings.heroImageUrl) { %>style="background-image:url('<%= websiteSettings.heroImageUrl %>')"<% } %>>
        <div class="hero-portrait-card">
          <span>Affixe</span>
          <strong><%= siteTitle %></strong>
          <% if (breeder.producer_number) { %><em>N° producteur : <%= breeder.producer_number %></em><% } %>
        </div>
      </aside>
    </section>

    <% if (websiteSettings.showIntro) { %>
      <section class="showcase-intro public-section editorial-intro">
        <div>
          <span class="section-kicker">Ligne d’élevage</span>
          <h2><%= websiteSettings.introTitle || 'Une sélection lisible, suivie et assumée' %></h2>
        </div>
        <p><%= websiteSettings.introText || websiteSettings.newsText || 'Nous privilégions une sélection cohérente : santé, tempérament, aptitude naturelle, équilibre familial et accompagnement durable des adoptants.' %></p>
      </section>
    <% } %>

    <% if (websiteSettings.showServices) { %>
      <section id="services" class="public-section services-showcase-section">
        <div class="section-title compact">
          <span class="section-kicker"><%= websiteSettings.serviceSectionKicker || 'Savoir-faire' %></span>
          <h2><%= websiteSettings.serviceSectionTitle || 'Nos services' %></h2>
        </div>
        <div class="service-panel-grid">
          <% [1, 2, 3].forEach((index) => { const title = websiteSettings[`service${index}Title`]; const text = websiteSettings[`service${index}Text`]; if (title || text) { %>
            <article class="service-panel service-panel-<%= index %>">
              <div>
                <span>0<%= index %></span>
                <h3><%= title || `Service ${index}` %></h3>
                <p><%= text || '' %></p>
              </div>
            </article>
          <% } }) %>
        </div>
      </section>
    <% } %>

    <section id="temoignages" class="public-section social-proof-section">
      <div class="section-title compact">
        <span class="section-kicker">Preuve sociale</span>
        <h2>Les problèmes que les éleveurs veulent enfin régler</h2>
        <p class="muted">Des situations fréquentes du terrain, transformées en axes concrets de pilotage.</p>
      </div>
      <div class="testimonial-grid">
        <article class="testimonial-card">
          <p>“Entre les vermifuges, les vaccins et les départs chiots, tout finit dans des carnets différents. Il me faut une vision claire, pas un tableau bricolé.”</p>
          <strong>Suivi sanitaire structuré</strong>
        </article>
        <article class="testimonial-card">
          <p>“Le vrai risque, ce n’est pas de manquer de passion. C’est d’oublier une échéance administrative ou de vendre un chiot avec un document incomplet.”</p>
          <strong>Alertes et documents maîtrisés</strong>
        </article>
        <article class="testimonial-card">
          <p>“Je veux savoir où en sont mes portées, mes réservations et ma trésorerie sans ouvrir dix fichiers. Un élevage sérieux doit se piloter proprement.”</p>
          <strong>Dashboard métier</strong>
        </article>
      </div>
    </section>

    <% if (websiteSettings.showPuppies) { %>
      <section id="chiots" class="public-section">
        <div class="section-title compact">
          <span class="section-kicker">Disponibilités</span>
          <h2>Chiots disponibles ou réservables</h2>
        </div>
        <% if (!puppies.length) { %>
          <div class="empty-state"><strong>Aucun chiot disponible actuellement</strong><p>Contactez l’élevage pour connaître les prochains projets de portée.</p></div>
        <% } else { %>
          <div class="public-card-grid premium-card-grid">
            <% puppies.forEach((puppy) => { %>
              <article class="public-card premium-card">
                <span class="badge"><%= puppy.status || 'Disponible' %></span>
                <h3><%= puppy.name || 'Chiot disponible' %></h3>
                <p><%= puppy.sex || '-' %> — <%= puppy.color || 'Robe non renseignée' %></p>
                <% if (puppy.mother_name) { %><p>Mère : <strong><%= puppy.mother_name %></strong></p><% } %>
                <% if (puppy.sale_price) { %><p class="public-price"><%= puppy.sale_price %> €</p><% } %>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>
    <% } %>

    <% if (websiteSettings.showLitters) { %>
      <section class="public-section">
        <div class="section-title compact">
          <span class="section-kicker">Portées</span>
          <h2>Portées en cours</h2>
        </div>
        <% if (!litters.length) { %>
          <p class="muted">Aucune portée active affichée.</p>
        <% } else { %>
          <div class="public-card-grid premium-card-grid litter-public-grid">
            <% litters.forEach((litter) => { const litterImages = (websiteSettings.litterGallery && websiteSettings.litterGallery[litter.id]) || []; %>
              <article class="public-card premium-card litter-public-card">
                <% if (litterImages[0]) { %><img class="litter-cover" src="<%= litterImages[0].url %>" alt="Photo portée"><% } %>
                <h3>Portée de <%= litter.mother_name || 'mère non renseignée' %></h3>
                <p>Née le <%= formatDate(litter.birth_date) %></p>
                <p><%= litter.puppies_count_total || litter.puppies_count || litter.nb_puppies || 0 %> chiot(s)</p>
                <% if (litterImages.length > 1) { %>
                  <div class="litter-thumbs">
                    <% litterImages.slice(1, 5).forEach((image) => { %><img src="<%= image.url %>" alt="Photo portée"><% }) %>
                  </div>
                <% } %>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>
    <% } %>

    <% if (websiteSettings.showDogs) { %>
      <section id="selection" class="public-section">
        <div class="section-title compact">
          <span class="section-kicker">Sélection</span>
          <h2>Nos chiens</h2>
        </div>
        <% if (!dogs.length) { %>
          <p class="muted">Aucun chien affiché pour le moment.</p>
        <% } else { %>
          <div class="public-card-grid premium-card-grid dogs-grid">
            <% dogs.forEach((dog) => { %>
              <article class="public-card premium-card dog-card">
                <span class="dog-sex"><%= dog.sex === 'M' ? 'Mâle' : 'Femelle' %></span>
                <h3><%= dog.name %></h3>
                <p><%= dog.breed || 'Race non renseignée' %></p>
                <% if (dog.lof) { %><p>LOF : <%= dog.lof %></p><% } %>
                <% if (dog.notes) { %><p class="dog-note"><%= String(dog.notes).slice(0, 160) %><%= String(dog.notes).length > 160 ? '…' : '' %></p><% } %>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>
    <% } %>

    <% if (websiteSettings.showGallery && websiteSettings.gallery && websiteSettings.gallery.length) { %>
      <section id="galerie" class="public-section">
        <div class="section-title compact">
          <span class="section-kicker">Galerie</span>
          <h2>Photos de l’élevage</h2>
        </div>
        <div class="public-gallery-grid">
          <% websiteSettings.gallery.forEach((image) => { %>
            <img src="<%= image.url %>" alt="Photo élevage">
          <% }) %>
        </div>
      </section>
    <% } %>

    <% if (websiteSettings.showStrengths && strengthsList.length) { %>
      <section class="public-section strengths-band">
        <div class="section-title compact">
          <span class="section-kicker"><%= websiteSettings.strengthsKicker || 'Nos points forts' %></span>
          <h2><%= websiteSettings.strengthsTitle || 'Pourquoi nous faire confiance' %></h2>
        </div>
        <div class="strengths-grid">
          <% strengthsList.slice(0, 4).forEach((strength, index) => { %>
            <article>
              <span><%= index + 1 %></span>
              <strong><%= strength %></strong>
            </article>
          <% }) %>
        </div>
      </section>
    <% } %>

    <% if (websiteSettings.showContact) { %>
      <section id="contact" class="public-section public-contact premium-contact">
        <div>
          <span class="section-kicker">Contact</span>
          <h2>Contacter l’élevage</h2>
          <% if (breeder.address) { %><p><%= breeder.address %></p><% } %>
          <% if (websiteSettings.openingHours) { %><p>Horaires : <%= websiteSettings.openingHours %></p><% } %>
          <% if (websiteSettings.phone) { %><p>Téléphone : <a href="tel:<%= websiteSettings.phone %>"><%= websiteSettings.phone %></a></p><% } %>
          <% if (websiteSettings.publicEmail) { %><p>Email : <a href="mailto:<%= websiteSettings.publicEmail %>"><%= websiteSettings.publicEmail %></a></p><% } %>
          <% if (websiteSettings.instagram) { %><p>Instagram : <%= websiteSettings.instagram %></p><% } %>
          <% if (websiteSettings.facebook) { %><p>Facebook : <%= websiteSettings.facebook %></p><% } %>
          <% if (breeder.siret) { %><p>SIRET : <%= breeder.siret %></p><% } %>
        </div>
        <div class="contact-panel">
          <strong><%= websiteSettings.contactPanelTitle || 'Engagement éleveur' %></strong>
          <p><%= websiteSettings.contactPanelText || 'Un élevage sérieux ne vend pas seulement un chiot : il transmet une lignée, une méthode et un suivi.' %></p>
        </div>
      </section>
    <% } %>

    <section class="final-cta-section">
      <div>
        <span class="section-kicker">ElevagePro</span>
        <h2>Pilotez votre élevage avec une vraie méthode.</h2>
        <p>Chiens, portées, chiots, soins, rappels, ventes et vitrine : centralisez votre activité dans un outil pensé pour le terrain.</p>
      </div>
      <a class="showcase-btn primary" href="<%= trialUrl %>">Créer mon élevage</a>
    </section>

    <footer class="showcase-footer">
      <div>
        <% if (logoUrl) { %><img src="<%= logoUrl %>" alt="Logo <%= siteTitle %>"><% } %>
        <strong><%= siteTitle %></strong>
        <p><%= websiteSettings.footerText || websiteSettings.siteSlogan || websiteSettings.heroSubtitle || 'Élevage canin familial.' %></p>
      </div>
      <div>
        <% if (breeder.address) { %><p><%= breeder.address %></p><% } %>
        <% if (websiteSettings.openingHours) { %><p><%= websiteSettings.openingHours %></p><% } %>
        <% if (websiteSettings.phone) { %><p><a href="tel:<%= websiteSettings.phone %>"><%= websiteSettings.phone %></a></p><% } %>
        <% if (websiteSettings.publicEmail) { %><p><a href="mailto:<%= websiteSettings.publicEmail %>"><%= websiteSettings.publicEmail %></a></p><% } %>
      </div>
    </footer>
  </main>
</body>
</html>
