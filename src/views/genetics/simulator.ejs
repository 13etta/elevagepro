<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<main class="container">
  <h1>Laboratoire Génétique : Simulation de Portée</h1>
  <p style="color: #7f8c8d; margin-top:-1rem; margin-bottom: 2rem;">
      Estimez le Coefficient de Consanguinité (COI) sur 5 générations avant de planifier une saillie.
  </p>

  <div class="form-grid" style="align-items: start;">
      
      <section class="form-block card">
        <h3 style="color: var(--primary-color); border-bottom: 1px solid #eee; padding-bottom: 0.5rem;">Sélection des reproducteurs</h3>
        <form action="/genetics/simulator" method="POST">
            <div class="form-group">
                <label for="sire_id">Étalon (Père)</label>
                <select id="sire_id" name="sire_id" required>
                    <option value="">Sélectionner le mâle</option>
                    <% males.forEach(m => { %>
                        <option value="<%= m.id %>"><%= m.name %></option>
                    <% }) %>
                </select>
            </div>

            <div class="form-group">
                <label for="dam_id">Lice (Mère)</label>
                <select id="dam_id" name="dam_id" required>
                    <option value="">Sélectionner la femelle</option>
                    <% females.forEach(f => { %>
                        <option value="<%= f.id %>"><%= f.name %></option>
                    <% }) %>
                </select>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 1rem;">Lancer la simulation COI</button>
        </form>
      </section>

      <section class="card" style="background-color: #fafafa;">
          <% if (!result) { %>
              <div style="text-align: center; padding: 3rem 1rem; color: #95a5a6;">
                  <span style="font-size: 3rem; display: block; margin-bottom: 1rem;">DNA</span>
                  <p>Sélectionnez un étalon et une lice pour afficher l'analyse génétique prédictive.</p>
              </div>
          <% } else { %>
              <h3 style="color: var(--accent-color); border-bottom: 1px solid #eee; padding-bottom: 0.5rem;">Résultat de l'analyse</h3>
              <p style="font-size: 1.1rem; text-align: center; margin: 1.5rem 0;">
                  Croisement : <strong><%= result.sireName %></strong> x <strong><%= result.damName %></strong>
              </p>
              
              <div style="text-align: center; background: #fff; padding: 2rem; border-radius: 8px; border: 2px solid <%= result.coiTotal > 12.5 ? '#e74c3c' : '#27ae60' %>; margin-bottom: 1.5rem;">
                  <span style="font-size: 0.9rem; color: #7f8c8d; text-transform: uppercase; letter-spacing: 1px;">Coefficient de Consanguinité</span>
                  <div style="font-size: 3.5rem; font-weight: bold; color: <%= result.coiTotal > 12.5 ? '#e74c3c' : '#27ae60' %>;">
                      <%= result.coiTotal %> %
                  </div>
                  <% if (result.coiTotal > 12.5) { %>
                      <small style="color: #e74c3c;">Risque de dépression consanguine élevé (Demi-frère/sœur ou équivalent).</small>
                  <% } else { %>
                      <small style="color: #27ae60;">Croisement acceptable (Outcross ou Linebreeding léger).</small>
                  <% } %>
              </div>

              <h4>Ancêtres communs identifiés</h4>
              <ul style="list-style: none; padding: 0;">
                  <% if (result.commonAncestors.length === 0) { %>
                      <li style="padding: 0.5rem; background: #e8f8f5; color: #1abc9c; border-radius: 4px;">Aucun ancêtre commun sur 5 générations.</li>
                  <% } else { %>
                      <% result.commonAncestors.forEach(anc => { %>
                          <li style="padding: 0.5rem 0; border-bottom: 1px solid #eee; display: flex; justify-content: space-between;">
                              <span><strong><%= anc.name %></strong> (Père: Gen <%= anc.genSire %> / Mère: Gen <%= anc.genDam %>)</span>
                              <span style="color: #7f8c8d;">+ <%= anc.contribution %> %</span>
                          </li>
                      <% }) %>
                  <% } %>
              </ul>
          <% } %>
      </section>

  </div>
</main>
<%- include('../partials/foot') %>