<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container">
    <div class="header-actions">
        <h1>Simulateur de Consanguinité (COI)</h1>
        <p style="color: #7f8c8d;">Calcul basé sur 5 générations selon la méthode de Wright</p>
    </div>

    <form action="/genetics/simulator" method="POST" class="card form-grid" style="margin-bottom: 2rem; background-color: #f8f9fa;">
        <div style="display: flex; gap: 1.5rem; flex-wrap: wrap; width: 100%; align-items: flex-end;">
            <div style="flex: 2;">
                <label style="display: block; margin-bottom: 0.5rem; font-weight: bold;">Choisir le Mâle</label>
                <select name="sire_id" style="width: 100%; padding: 0.6rem; border-radius: 4px; border: 1px solid #ccc;" required>
                    <option value="">-- Sélectionner --</option>
                    <% males.forEach(m => { %>
                        <option value="<%= m.id %>"><%= m.name %></option>
                    <% }) %>
                </select>
            </div>
            <div style="flex: 2;">
                <label style="display: block; margin-bottom: 0.5rem; font-weight: bold;">Choisir la Femelle</label>
                <select name="dam_id" style="width: 100%; padding: 0.6rem; border-radius: 4px; border: 1px solid #ccc;" required>
                    <option value="">-- Sélectionner --</option>
                    <% females.forEach(f => { %>
                        <option value="<%= f.id %>"><%= f.name %></option>
                    <% }) %>
                </select>
            </div>
            <div style="flex: 1;">
                <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.7rem;">Calculer le COI</button>
            </div>
        </div>
    </form>

    <% if (result) { %>
        <section class="card" style="border-left: 5px solid #2c3e50;">
            <div style="text-align: center; padding: 1rem 0;">
                <h2 style="margin-bottom: 0.5rem;">Résultat de l'alliance</h2>
                <p><%= result.sireName %> × <%= result.damName %></p>
                <div style="font-size: 3rem; font-weight: bold; color: #e74c3c; margin: 1rem 0;">
                    <%= result.coiTotal %> %
                </div>
                <p style="color: #7f8c8d;">Coefficient de consanguinité total</p>
            </div>

            <% if (result.commonAncestors.length > 0) { %>
                <div style="margin-top: 2rem;">
                    <h3>Ancêtres communs détectés</h3>
                    <div class="table-responsive">
                        <table class="table" style="width: 100%; margin-top: 1rem;">
                            <thead>
                                <tr style="background-color: #eee; text-align: left;">
                                    <th style="padding: 0.8rem;">Ancêtre</th>
                                    <th style="padding: 0.8rem;">Gén. (Père)</th>
                                    <th style="padding: 0.8rem;">Gén. (Mère)</th>
                                    <th style="padding: 0.8rem; text-align: right;">Contribution</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% result.commonAncestors.forEach(anc => { %>
                                    <tr style="border-bottom: 1px solid #eee;">
                                        <td style="padding: 0.8rem;"><strong><%= anc.name %></strong></td>
                                        <td style="padding: 0.8rem;"><%= anc.genSire %></td>
                                        <td style="padding: 0.8rem;"><%= anc.genDam %></td>
                                        <td style="padding: 0.8rem; text-align: right;"><%= anc.contribution %> %</td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            <% } else { %>
                <p style="text-align: center; color: #27ae60; font-weight: bold; margin-top: 1rem;">Aucun ancêtre commun trouvé sur 5 générations.</p>
            <% } %>
        </section>
    <% } %>
</main>

<%- include('../partials/foot') %>