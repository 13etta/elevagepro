<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container">
  <section class="page-hero">
    <div>
      <p class="eyebrow">Fiche portée</p>
      <h1>Portée de <%= litter.mother_name || 'mère inconnue' %></h1>
      <p>
        Mise bas le <%= litter.birth_date ? formatDate(litter.birth_date) : '-' %>
        — <%= puppies.length %> chiots enregistrés sur <%= litter.puppies_count_total || 0 %> déclarés.
      </p>
    </div>
    <div class="topbar-actions">
      <a href="/litters" class="btn btn-secondary">Retour</a>
      <a href="/litters/<%= litter.id %>/edit" class="btn btn-secondary">Modifier</a>
      <a href="/puppies/new?litter_id=<%= litter.id %>" class="btn btn-primary">Ajouter un chiot</a>
    </div>
  </section>

  <section class="kpi-grid">
    <article class="kpi-card"><span>Statut</span><strong><%= litter.status || '-' %></strong></article>
    <article class="kpi-card"><span>Chiots déclarés</span><strong><%= litter.puppies_count_total || 0 %></strong></article>
    <article class="kpi-card"><span>Chiots créés</span><strong><%= puppies.length %></strong></article>
    <article class="kpi-card"><span>Date naissance</span><strong><%= litter.birth_date ? formatDate(litter.birth_date) : '-' %></strong></article>
  </section>

  <section class="dashboard-columns">
    <article class="card">
      <div class="section-title compact">
        <span class="section-kicker">Reproduction</span>
        <h2>Informations de portée</h2>
      </div>
      <p><strong>Mère :</strong> <%= litter.mother_name || '-' %></p>
      <p><strong>Naissance :</strong> <%= litter.birth_date ? formatDate(litter.birth_date) : '-' %></p>
      <p><strong>Statut :</strong> <span class="badge"><%= litter.status || '-' %></span></p>
    </article>

    <article class="card">
      <div class="section-title compact">
        <span class="section-kicker">Notes</span>
        <h2>Observations</h2>
      </div>
      <p><%= litter.notes || 'Aucune observation renseignée.' %></p>
    </article>
  </section>

  <section class="table-block">
    <div class="section-title compact">
      <span class="section-kicker">Suivi individuel</span>
      <h2>Chiots de la portée</h2>
    </div>

    <% if (!puppies.length) { %>
      <div class="empty-logo-preview">
        <strong>0</strong>
        <p>Aucun chiot n’a encore été créé pour cette portée.</p>
      </div>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Nom</th>
            <th>Sexe</th>
            <th>Robe</th>
            <th>Puce</th>
            <th>Statut</th>
            <th>Prix</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% puppies.forEach((puppy) => { %>
            <tr>
              <td><strong><%= puppy.name || 'Chiot sans nom' %></strong></td>
              <td><%= puppy.sex || '-' %></td>
              <td><%= puppy.color || '-' %></td>
              <td><%= puppy.chip_number || '-' %></td>
              <td><span class="badge"><%= puppy.status || '-' %></span></td>
              <td><%= puppy.sale_price ? puppy.sale_price + ' €' : '-' %></td>
              <td class="table-actions">
                <a class="btn btn-secondary" href="/puppies/<%= puppy.id %>">Voir fiche</a>
                <a class="btn btn-secondary" href="/puppies/edit/<%= puppy.id %>">Modifier</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </section>
</main>

<%- include('../partials/foot') %>
