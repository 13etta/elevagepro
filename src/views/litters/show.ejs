<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<main class="container">
  <div class="header-actions">
      <h1>Portée de <%= litter.mother_name %></h1>
      <a href="/litters" class="btn btn-secondary">Retour aux portées</a>
  </div>

  <p style="margin-top: -1.5rem; margin-bottom: 2rem; color: #7f8c8d;">
      Mise bas le <%= new Date(litter.birth_date).toLocaleDateString('fr-FR') %> • <%= puppies.length %> chiots générés.
  </p>

  <div class="kpi-grid">
    <% puppies.forEach(puppy => { %>
      <article class="card" style="padding: 1rem;">
        <form action="/litters/puppies/<%= puppy.id %>/edit" method="POST">
            <h3 style="margin-top:0; color: var(--primary-color); border-bottom: 1px solid #eee; padding-bottom: 0.5rem;"><%= puppy.name %></h3>
            
            <div style="margin-bottom: 0.5rem;">
                <label style="font-size: 0.8rem; font-weight: bold;">Nom</label>
                <input type="text" name="name" value="<%= puppy.name %>" style="width: 100%; padding: 0.3rem; margin-top: 0.2rem;" required>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 0.5rem;">
                <div>
                    <label style="font-size: 0.8rem; font-weight: bold;">Sexe</label>
                    <select name="sex" style="width: 100%; padding: 0.3rem; margin-top: 0.2rem;">
                        <option value="" <%= !puppy.sex ? 'selected' : '' %>>-</option>
                        <option value="M" <%= puppy.sex === 'M' ? 'selected' : '' %>>Mâle</option>
                        <option value="F" <%= puppy.sex === 'F' ? 'selected' : '' %>>Femelle</option>
                    </select>
                </div>
                <div>
                    <label style="font-size: 0.8rem; font-weight: bold;">Statut</label>
                    <select name="status" style="width: 100%; padding: 0.3rem; margin-top: 0.2rem;">
                        <option value="disponible" <%= puppy.status === 'disponible' ? 'selected' : '' %>>Disponible</option>
                        <option value="reserve" <%= puppy.status === 'reserve' ? 'selected' : '' %>>Réservé</option>
                        <option value="vendu" <%= puppy.status === 'vendu' ? 'selected' : '' %>>Vendu</option>
                    </select>
                </div>
            </div>

            <div style="margin-bottom: 0.5rem;">
                <label style="font-size: 0.8rem; font-weight: bold;">Couleur / Robe</label>
                <input type="text" name="color" value="<%= puppy.color || '' %>" style="width: 100%; padding: 0.3rem; margin-top: 0.2rem;">
            </div>

            <div style="margin-bottom: 0.5rem;">
                <label style="font-size: 0.8rem; font-weight: bold;">Numéro Puce</label>
                <input type="text" name="chip_number" value="<%= puppy.chip_number || '' %>" style="width: 100%; padding: 0.3rem; margin-top: 0.2rem;">
            </div>

            <div style="margin-bottom: 1rem;">
                <label style="font-size: 0.8rem; font-weight: bold;">Prix de vente (€)</label>
                <input type="number" step="0.01" name="sale_price" value="<%= puppy.sale_price || '' %>" style="width: 100%; padding: 0.3rem; margin-top: 0.2rem;">
            </div>
<% if (puppy.status === 'reserve') { %>
    <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px dashed #ccc;">
        <button type="button" class="btn btn-primary" style="background: #27ae60; width: 100%;" onclick="document.getElementById('sale-form-<%= puppy.id %>').style.display='block'">Finaliser la vente</button>
    </div>

    <div id="sale-form-<%= puppy.id %>" style="display:none; margin-top: 1rem; background: #eee; padding: 1rem; border-radius: 5px;">
        <form action="/sales/new" method="POST">
            <input type="hidden" name="puppy_id" value="<%= puppy.id %>">
            <input type="text" name="buyer_name" placeholder="Nom de l'acheteur" required style="width:100%; margin-bottom: 0.5rem;">
            <input type="date" name="sale_date" required style="width:100%; margin-bottom: 0.5rem;">
            <input type="number" name="price" placeholder="Prix final" value="<%= puppy.sale_price %>" required style="width:100%; margin-bottom: 0.5rem;">
            <select name="payment_method" style="width:100%; margin-bottom: 0.5rem;">
                <option value="Virement">Virement</option>
                <option value="Chèque">Chèque</option>
                <option value="Espèces">Espèces</option>
            </select>
            <button type="submit" class="btn btn-primary" style="width:100%;">Valider la vente</button>
        </form>
    </div>
<% } %>
            <button type="submit" class="btn btn-primary" style="width: 100%; font-size: 0.8rem; padding: 0.4rem;">Sauvegarder</button>
        </form>
      </article>
    <% }) %>
  </div>
</main>
<%- include('../partials/foot') %>