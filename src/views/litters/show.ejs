<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container">
    <div class="header-actions" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1>Portée de <%= litter.mother_name %> (Mère)</h1>
            <p style="color: #7f8c8d; margin-top: 0.5rem;">
                Mise bas le <%= new Date(litter.birth_date).toLocaleDateString('fr-FR') %> • <%= puppies.length %> chiots enregistrés sur <%= litter.puppies_count_total %> déclarés.
            </p>
        </div>
        <a href="/litters" class="btn btn-secondary" style="background-color: #f1f3f5; color: #333; border: none;">Retour aux portées</a>
    </div>

    <% if (puppies.length === 0) { %>
        <div style="text-align: center; padding: 3rem; background: #fff; border-radius: 8px; border: 1px solid #eee;">
            <p style="color: #7f8c8d; margin-bottom: 1rem;">Aucun chiot n'a encore été créé pour cette portée.</p>
        </div>
    <% } else { %>
        <% puppies.forEach((puppy, index) => { %>
            <div class="card form-block" style="margin-bottom: 2rem;">
                <h3 style="border-bottom: 1px solid #eee; padding-bottom: 0.5rem; margin-bottom: 1.5rem;">Chiot <%= index + 1 %></h3>
                
                <form action="/puppies/<%= puppy.id %>/edit" method="POST">
                    <input type="hidden" name="redirect_to" value="/litters/<%= litter.id %>">
                    
                    <div class="form-group" style="margin-bottom: 1rem;">
                        <label>Nom</label>
                        <input type="text" name="name" value="<%= puppy.name %>" required style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;">
                    </div>

                    <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                        <div class="form-group">
                            <label>Sexe</label>
                            <select name="sex" style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;">
                                <option value="M" <%= puppy.sex === 'M' ? 'selected' : '' %>>Mâle</option>
                                <option value="F" <%= puppy.sex === 'F' ? 'selected' : '' %>>Femelle</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Statut</label>
                            <select name="status" style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;">
                                <option value="Disponible" <%= puppy.status === 'Disponible' ? 'selected' : '' %>>Disponible</option>
                                <option value="Réservé" <%= puppy.status === 'Réservé' ? 'selected' : '' %>>Réservé</option>
                                <option value="Vendu" <%= puppy.status === 'Vendu' ? 'selected' : '' %>>Vendu</option>
                                <option value="Décédé" <%= puppy.status === 'Décédé' ? 'selected' : '' %>>Décédé</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group" style="margin-bottom: 1rem;">
                        <label>Couleur / Robe</label>
                        <input type="text" name="color" value="<%= puppy.color || '' %>" style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;">
                    </div>

                    <div class="form-group" style="margin-bottom: 1rem;">
                        <label>Numéro Puce</label>
                        <input type="text" name="chip_number" value="<%= puppy.chip_number || '' %>" style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;">
                    </div>

                    <div class="form-group" style="margin-bottom: 2rem;">
                        <label>Prix de vente (€)</label>
                        <input type="number" step="0.01" name="sale_price" value="<%= puppy.sale_price || '' %>" style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;">
                    </div>

                    <button type="submit" style="width: 100%; padding: 0.75rem; background-color: #2c3e50; color: white; border: none; border-radius: 4px; font-weight: bold; cursor: pointer;">Sauvegarder</button>
                </form>
            </div>
        <% }) %>
    <% } %>

    <div style="text-align: center; margin-top: 2rem;">
        <a href="/puppies/new?litter_id=<%= litter.id %>" class="btn btn-primary" style="padding: 1rem 2rem; font-size: 1.1rem;">+ Ajouter un nouveau chiot à la portée</a>
    </div>

</main>

<%- include('../partials/foot') %>