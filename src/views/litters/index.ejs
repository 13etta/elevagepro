<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container">
    <div class="header-actions" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
        <div>
            <h1>Naissances & Portées</h1>
            <p style="color: #7f8c8d; margin-top:-0.5rem;">Suivi des mises bas et gestion des chiots</p>
        </div>
        <a href="/litters/new" class="btn btn-primary">Déclarer une portée</a>
    </div>

    <form method="GET" action="/litters" class="card form-grid" style="margin-bottom: 2rem; padding: 1.5rem; background-color: #f8f9fa; border: 1px solid #e9ecef;">
        <div style="display: flex; gap: 1rem; flex-wrap: wrap; width: 100%;">
            <input type="text" name="q" placeholder="Recherche (notes...)" value="<%= filters && filters.q ? filters.q : '' %>" style="flex: 2; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;">
            
            <select name="female_id" style="flex: 1; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;">
                <option value="">-- Mère --</option>
                <% females.forEach(f => { %>
                    <option value="<%= f.id %>" <%= filters && filters.female_id == f.id ? 'selected' : '' %>><%= f.name %></option>
                <% }) %>
            </select>

            <select name="status" style="flex: 1; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;">
                <option value="">-- Statut --</option>
                <option value="active" <%= filters && filters.status === 'active' ? 'selected' : '' %>>Active (Nouveau-nés)</option>
                <option value="sevrage" <%= filters && filters.status === 'sevrage' ? 'selected' : '' %>>En sevrage</option>
                <option value="terminee" <%= filters && filters.status === 'terminee' ? 'selected' : '' %>>Terminée</option>
            </select>

            <button type="submit" class="btn btn-secondary">Filtrer</button>
            <a href="/litters" class="btn btn-outline-secondary" style="display: flex; align-items: center; text-decoration: none; color: #6c757d; border: 1px solid #ccc; padding: 0.5rem 1rem; border-radius: 4px;">Réinitialiser</a>
        </div>
    </form>

    <section class="card">
        <% if (litters.length === 0) { %>
            <p style="text-align: center; color: #7f8c8d; padding: 3rem;">Aucune portée trouvée.</p>
        <% } else { %>
            <div class="table-responsive">
                <table class="table" style="width: 100%; text-align: left; border-collapse: collapse;">
                    <thead style="background-color: #f8f9fa; border-bottom: 2px solid #dee2e6;">
                        <tr>
                            <th style="padding: 1rem;">Mère</th>
                            <th style="padding: 1rem;">Mise bas</th>
                            <th style="padding: 1rem;">Chiots</th>
                            <th style="padding: 1rem;">Statut</th>
                            <th style="padding: 1rem; text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% litters.forEach(l => { %>
                            <tr style="border-bottom: 1px solid #eee;">
                                <td style="padding: 1rem;"><strong><%= l.mother_name || 'Inconnue' %></strong></td>
                                <td style="padding: 1rem;"><%= new Date(l.birth_date).toLocaleDateString('fr-FR') %></td>
                                <td style="padding: 1rem;"><%= l.puppies_count_total %></td>
                                <td style="padding: 1rem;">
                                    <% if (l.status === 'active') { %>
                                        <span style="background-color: #e8fdf5; color: #198754; padding: 0.3rem 0.6rem; border-radius: 4px; font-size: 0.85rem; font-weight: bold;">Active</span>
                                    <% } else if (l.status === 'terminee') { %>
                                        <span style="background-color: #f8f9fa; color: #6c757d; padding: 0.3rem 0.6rem; border-radius: 4px; font-size: 0.85rem;">Terminée</span>
                                    <% } else { %>
                                        <span style="background-color: #fff3cd; color: #856404; padding: 0.3rem 0.6rem; border-radius: 4px; font-size: 0.85rem;"><%= l.status %></span>
                                    <% } %>
                                </td>
                                <td style="padding: 1rem; text-align: right; display: flex; justify-content: flex-end; gap: 0.5rem;">
                                    <a href="/litters/<%= l.id %>" class="btn btn-primary btn-sm">Gérer les chiots</a>
                                    <a href="/litters/<%= l.id %>/edit" class="btn btn-secondary btn-sm">Modifier</a>
                                    <form action="/litters/<%= l.id %>/delete" method="POST" onsubmit="return confirm('Supprimer cette portée ?');">
                                        <button type="submit" class="btn btn-sm" style="background-color: #ffeaea; color: #dc3545; border: 1px solid #ffc2c2;">Supprimer</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </section>
</main>

<%- include('../partials/foot') %>