<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container">
    <div class="header-actions">
        <h1>Ajouter une chaleur</h1>
        <a href="/heats" class="btn btn-secondary">Annuler</a>
    </div>

    <form action="/heats/new" method="POST" class="card form-block">
        <div class="form-group">
            <label for="dog_id">Chienne concernée *</label>
            <select id="dog_id" name="dog_id" required>
                <option value="">-- Choisir une femelle active --</option>
                <% females.forEach(f => { %>
                    <option value="<%= f.id %>"><%= f.name %></option>
                <% }) %>
            </select>
        </div>

        <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1rem;">
            <div class="form-group">
                <label for="start_date">Date de début *</label>
                <input type="date" id="start_date" name="start_date" required>
            </div>
            <div class="form-group">
                <label for="end_date">Date de fin (estimée ou réelle)</label>
                <input type="date" id="end_date" name="end_date">
            </div>
        </div>

        <div class="form-group" style="margin-top: 1rem;">
            <label for="stage">Phase du cycle</label>
            <select id="stage" name="stage">
                <option value="">-- Non précisé --</option>
                <option value="Prooestrus (Début)">Prooestrus (Pertes / Début)</option>
                <option value="Oestrus (Ovulation)">Oestrus (Acceptation / Ovulation)</option>
                <option value="Metoestrus (Fin)">Metoestrus (Refus / Fin)</option>
            </select>
        </div>

        <div class="form-group" style="margin-top: 1rem;">
            <label for="notes">Observations (Taux de progestérone, comportement...)</label>
            <textarea id="notes" name="notes" rows="3" placeholder="Ex: Frottis réalisé le... Progestérone à 5ng..."></textarea>
        </div>

        <div style="margin-top: 2rem; border-top: 1px solid #eee; padding-top: 1.5rem;">
            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem; font-size: 1.1rem;">Enregistrer le cycle</button>
        </div>
    </form>
</main>

<%- include('../partials/foot') %>