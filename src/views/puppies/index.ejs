<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container">
  <section class="page-hero">
    <div>
      <p class="eyebrow">Cheptel jeune</p>
      <h1>Chiots</h1>
      <p>Suivez les chiots issus de vos portées : sexe, robe, identification, statut commercial et prix prévisionnel.</p>
    </div>
    <a class="btn btn-primary" href="/puppies/new">Ajouter un chiot</a>
  </section>

  <section class="table-block puppy-filter-panel">
    <div class="section-title compact">
      <span class="section-kicker">Filtres avancés</span>
      <h2>Recherche opérationnelle</h2>
    </div>

    <form id="puppyFilters" class="puppy-filters">
      <div class="form-group">
        <label for="q">Recherche</label>
        <input id="q" type="search" name="q" value="<%= filters.q || '' %>" placeholder="Nom, puce, robe, statut...">
      </div>

      <div class="form-group">
        <label for="sex">Sexe</label>
        <select id="sex" name="sex">
          <option value="">Tous</option>
          <option value="M" <%= filters.sex === 'M' ? 'selected' : '' %>>Mâle</option>
          <option value="F" <%= filters.sex === 'F' ? 'selected' : '' %>>Femelle</option>
        </select>
      </div>

      <div class="form-group">
        <label for="color">Robe</label>
        <select id="color" name="color">
          <option value="">Toutes</option>
          <% colors.forEach((color) => { %>
            <option value="<%= color %>" <%= filters.color === color ? 'selected' : '' %>><%= color %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="status">Statut</label>
        <select id="status" name="status">
          <option value="">Tous</option>
          <% statuses.forEach((status) => { %>
            <option value="<%= status %>" <%= filters.status === status ? 'selected' : '' %>><%= status %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="sale_state">Vente</label>
        <select id="sale_state" name="sale_state">
          <option value="">Tous</option>
          <option value="available" <%= filters.sale_state === 'available' ? 'selected' : '' %>>Disponible</option>
          <option value="reserved" <%= filters.sale_state === 'reserved' ? 'selected' : '' %>>Réservé / option</option>
          <option value="sold" <%= filters.sale_state === 'sold' ? 'selected' : '' %>>Vendu</option>
        </select>
      </div>

      <button class="btn btn-secondary" type="button" id="resetPuppyFilters">Réinitialiser</button>
    </form>
  </section>

  <section class="table-block">
    <div class="section-title compact table-toolbar">
      <div>
        <span class="section-kicker">Suivi</span>
        <h2>Liste des chiots</h2>
      </div>
      <p id="puppyFilterStatus" class="muted"><span id="puppyCount"><%= puppies.length %></span> chiot(s) affiché(s)</p>
    </div>

    <table>
      <thead>
        <tr>
          <th>Nom / Collier</th>
          <th>Sexe</th>
          <th>Robe</th>
          <th>Puce</th>
          <th>Portée</th>
          <th>Statut</th>
          <th>Prix</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="puppyRows">
        <%- include('./_rows', { puppies }) %>
      </tbody>
    </table>
  </section>
</main>

<script>
(() => {
  const form = document.getElementById('puppyFilters');
  const rows = document.getElementById('puppyRows');
  const count = document.getElementById('puppyCount');
  const status = document.getElementById('puppyFilterStatus');
  const resetButton = document.getElementById('resetPuppyFilters');

  let timer = null;
  let controller = null;

  function cleanParams() {
    const params = new URLSearchParams(new FormData(form));
    const clean = new URLSearchParams();

    for (const [key, value] of params.entries()) {
      if (value && value.trim() !== '') {
        clean.append(key, value.trim());
      }
    }

    return clean;
  }

  async function refreshPuppies() {
    if (controller) controller.abort();
    controller = new AbortController();

    const params = cleanParams();
    status.classList.add('is-loading');

    try {
      const response = await fetch(`/puppies/fragment?${params.toString()}`, {
        headers: { 'X-Requested-With': 'fetch' },
        signal: controller.signal,
      });

      if (!response.ok) throw new Error('Filtrage indisponible');

      rows.innerHTML = await response.text();
      count.textContent = rows.querySelectorAll('[data-puppy-row]').length;

      window.history.replaceState({}, '', params.toString() ? `/puppies?${params.toString()}` : '/puppies');
    } catch (error) {
      if (error.name !== 'AbortError') console.error(error);
    } finally {
      status.classList.remove('is-loading');
    }
  }

  function scheduleRefresh() {
    clearTimeout(timer);
    timer = setTimeout(refreshPuppies, 250);
  }

  form.addEventListener('input', scheduleRefresh);
  form.addEventListener('change', scheduleRefresh);

  resetButton.addEventListener('click', () => {
    form.reset();
    refreshPuppies();
  });
})();
</script>

<%- include('../partials/foot') %>
