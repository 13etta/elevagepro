<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container">
  <section class="page-hero">
    <div>
      <p class="eyebrow">Cheptel jeune</p>
      <h1>Chiots</h1>
      <p>Suivez les chiots issus de vos portées : sexe, robe, identification, statut commercial et prix prévisionnel.</p>
    </div>
    <a class="btn btn-primary" href="/puppies/new">Ajouter un chiot</a>
  </section>

  <section class="table-block">
    <div class="section-title compact">
      <span class="section-kicker">Suivi</span>
      <h2>Liste des chiots</h2>
    </div>

    <% if (!puppies.length) { %>
      <div class="empty-logo-preview">
        <strong>0</strong>
        <p>Aucun chiot enregistré pour le moment.</p>
      </div>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Nom / Collier</th>
            <th>Sexe</th>
            <th>Robe</th>
            <th>Puce</th>
            <th>Portée</th>
            <th>Statut</th>
            <th>Prix</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% puppies.forEach((puppy) => { %>
            <tr>
              <td><strong><%= puppy.name || '-' %></strong></td>
              <td><%= puppy.sex || '-' %></td>
              <td><%= puppy.color || '-' %></td>
              <td><%= puppy.chip_number || '-' %></td>
              <td>
                <% if (puppy.mother_name || puppy.litter_birth_date) { %>
                  <%= puppy.mother_name || 'Portée' %>
                  <% if (puppy.litter_birth_date) { %>
                    <br><small><%= formatDate(puppy.litter_birth_date) %></small>
                  <% } %>
                <% } else { %>
                  -
                <% } %>
              </td>
              <td><span class="badge"><%= puppy.status || '-' %></span></td>
              <td><%= puppy.sale_price ? puppy.sale_price + ' €' : '-' %></td>
              <td class="table-actions">
                <a class="btn btn-secondary" href="/puppies/edit/<%= puppy.id %>">Modifier</a>
                <a class="btn btn-secondary" href="/puppies/delete/<%= puppy.id %>" onclick="return confirm('Supprimer ce chiot ?')">Supprimer</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </section>
</main>

<%- include('../partials/foot') %>
