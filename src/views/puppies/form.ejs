<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container">
    <div class="header-actions">
        <h1><%= puppy.id ? "Modifier le" : "Ajouter un" %> chiot</h1>
        <% if (puppy.litter_id) { %>
            <a href="/litters/<%= puppy.litter_id %>" class="btn btn-secondary">Retour à la portée</a>
        <% } else { %>
            <a href="/puppies" class="btn btn-secondary">Retour à la liste</a>
        <% } %>
    </div>

    <form id="puppyForm" action="<%= puppy.id ? '/puppies/' + puppy.id + '/edit' : '/puppies/new' %>" method="POST" class="card form-block needs-validation" novalidate>
        
       <div class="form-grid">
    <div class="form-group">
        <label for="litter_select">Portée d'appartenance *</label>
        <select id="litter_select" name="litter_id" required style="background-color: #f8f9fa;">
            <option value="">-- Choisir une portée --</option>
            <% litters.forEach(l => { %>
                <option value="<%= l.id %>" 
                        data-birth="<%= new Date(l.birth_date).toISOString().split('T')[0] %>"
                        <%= puppy.litter_id === l.id ? 'selected' : '' %>>
                    Portée de <%= l.mother_name %> (Née le <%= new Date(l.birth_date).toLocaleDateString('fr-FR') %>)
                </option>
            <% }) %>
        </select>
        <small class="field-error">La portée est obligatoire.</small>
    </div>
    <div class="form-group">
        <label for="puppy_birth_date">Date de naissance exacte</label>
        <input type="date" id="puppy_birth_date" name="birth_date" 
               value="<%= puppy.birth_date ? new Date(puppy.birth_date).toISOString().split('T')[0] : '' %>">
    </div>
</div>
        
        <div class="form-grid" style="margin-top: 1rem;">
            <div class="form-group">
                <label for="puppy_name">Nom ou Collier *</label>
                <input id="puppy_name" type="text" name="name" value="<%= puppy.name || '' %>" required minlength="2" maxlength="80" placeholder="Ex: Collier Rouge, ou Nom définitif">
                <small class="field-error">Indique au minimum 2 caractères.</small>
            </div>
            <div class="form-group">
                <label for="puppy_sex">Sexe *</label>
                <select id="puppy_sex" name="sex" required>
                    <option value="">-- Choisir --</option>
                    <option value="M" <%= puppy.sex === 'M' ? 'selected' : '' %>>Mâle</option>
                    <option value="F" <%= puppy.sex === 'F' ? 'selected' : '' %>>Femelle</option>
                </select>
                <small class="field-error">Le sexe est obligatoire.</small>
            </div>
        </div>

        <div class="form-grid" style="margin-top: 1rem;">
            <div class="form-group">
                <label for="puppy_color">Couleur / Robe</label>
                <input id="puppy_color" type="text" name="color" value="<%= puppy.color || '' %>" maxlength="100" placeholder="Ex: lemon, blue belton, tricolore...">
            </div>
            <div class="form-group">
                <label for="puppy_chip">Numéro de puce</label>
                <input id="puppy_chip" type="text" name="chip_number" value="<%= puppy.chip_number || '' %>" placeholder="25026..." inputmode="numeric" pattern="[0-9A-Za-z -]{6,30}" maxlength="30">
                <small class="field-error">Format de puce invalide.</small>
            </div>
        </div>

        <div class="form-grid" style="margin-top: 1rem;">
            <div class="form-group">
                <label for="puppy_status">Statut</label>
                <select id="puppy_status" name="status">
                    <option value="Actif" <%= puppy.status === 'Actif' ? 'selected' : '' %>>Disponible (Actif)</option>
                    <option value="Réservé" <%= puppy.status === 'Réservé' ? 'selected' : '' %>>Réservé</option>
                    <option value="Vendu" <%= puppy.status === 'Vendu' ? 'selected' : '' %>>Vendu</option>
                    <option value="Décédé" <%= puppy.status === 'Décédé' ? 'selected' : '' %>>Décédé</option>
                </select>
            </div>
            <div class="form-group">
                <label for="puppy_price">Prix de vente attendu</label>
                <input id="puppy_price" type="number" min="0" step="0.01" name="sale_price" value="<%= puppy.sale_price || '' %>" placeholder="Ex: 1200">
                <small class="field-error">Le prix doit être positif.</small>
            </div>
        </div>

        <div class="form-group" style="margin-top: 1rem;">
            <label for="puppy_notes">Notes & Particularités</label>
            <textarea id="puppy_notes" name="notes" rows="3" maxlength="2000"><%= puppy.notes || '' %></textarea>
        </div>

        <div style="margin-top: 2rem;">
            <button id="savePuppyButton" type="submit" class="btn btn-primary btn-loading" style="width: 100%; padding: 1rem;">
                <span class="btn-label">Enregistrer le chiot</span>
                <span class="btn-spinner" aria-hidden="true"></span>
            </button>
        </div>
    </form>
</main>

<script>
(() => {
    const litterSelect = document.getElementById('litter_select');
    const birthDateInput = document.getElementById('puppy_birth_date');
    const form = document.getElementById('puppyForm');
    const saveButton = document.getElementById('savePuppyButton');

    if (litterSelect && birthDateInput) {
        litterSelect.addEventListener('change', function() {
            const selectedOption = this.options[this.selectedIndex];
            const birthDate = selectedOption.getAttribute('data-birth');
            if (birthDate) birthDateInput.value = birthDate;
        });
    }

    form.addEventListener('submit', function(event) {
        if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
            form.classList.add('was-validated');
            const firstInvalid = form.querySelector(':invalid');
            if (firstInvalid) firstInvalid.focus();
            return;
        }

        saveButton.disabled = true;
        saveButton.classList.add('is-loading');
        saveButton.querySelector('.btn-label').textContent = 'Sauvegarde en cours...';
    });
})();
</script>

<%- include('../partials/foot') %>