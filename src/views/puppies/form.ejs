<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container">
    <div class="header-actions">
        <h1><%= puppy.id ? "Modifier le" : "Ajouter un" %> chiot</h1>
        <% if (puppy.litter_id) { %>
            <a href="/litters/<%= puppy.litter_id %>" class="btn btn-secondary">Retour à la portée</a>
        <% } else { %>
            <a href="/puppies" class="btn btn-secondary">Retour à la liste</a>
        <% } %>
    </div>

    <form action="<%= puppy.id ? '/puppies/' + puppy.id + '/edit' : '/puppies/new' %>" method="POST" class="card form-block">
        
       <div class="form-grid">
    <div class="form-group">
        <label>Portée d'appartenance *</label>
        <select id="litter_select" name="litter_id" required style="background-color: #f8f9fa;">
            <option value="">-- Choisir une portée --</option>
            <% litters.forEach(l => { %>
                <option value="<%= l.id %>" 
                        data-birth="<%= new Date(l.birth_date).toISOString().split('T')[0] %>"
                        <%= puppy.litter_id === l.id ? 'selected' : '' %>>
                    Portée de <%= l.mother_name %> (Née le <%= new Date(l.birth_date).toLocaleDateString('fr-FR') %>)
                </option>
            <% }) %>
        </select>
    </div>
    <div class="form-group">
        <label>Date de naissance exacte</label>
        <input type="date" id="puppy_birth_date" name="birth_date" 
               value="<%= puppy.birth_date ? new Date(puppy.birth_date).toISOString().split('T')[0] : '' %>">
    </div>
</div>

<script>
document.getElementById('litter_select').addEventListener('change', function() {
    const selectedOption = this.options[this.selectedIndex];
    const birthDate = selectedOption.getAttribute('data-birth');
    if (birthDate) {
        document.getElementById('puppy_birth_date').value = birthDate;
    }
});
</script>
        
        <div class="form-grid" style="margin-top: 1rem;">
            <div class="form-group">
                <label>Nom ou Collier *</label>
                <input type="text" name="name" value="<%= puppy.name || '' %>" required placeholder="Ex: Collier Rouge, ou Nom définitif">
            </div>
            <div class="form-group">
                <label>Sexe *</label>
                <select name="sex" required>
                    <option value="M" <%= puppy.sex === 'M' ? 'selected' : '' %>>Mâle</option>
                    <option value="F" <%= puppy.sex === 'F' ? 'selected' : '' %>>Femelle</option>
                </select>
            </div>
        </div>

        <div class="form-grid" style="margin-top: 1rem;">
            <div class="form-group">
                <label>Couleur / Robe</label>
                <input type="text" name="color" value="<%= puppy.color || '' %>">
            </div>
            <div class="form-group">
                <label>Numéro de puce</label>
                <input type="text" name="chip_number" value="<%= puppy.chip_number || '' %>" placeholder="25026...">
            </div>
        </div>

        <div class="form-grid" style="margin-top: 1rem;">
            <div class="form-group">
                <label>Statut</label>
                <select name="status">
                    <option value="Actif" <%= puppy.status === 'Actif' ? 'selected' : '' %>>Disponible (Actif)</option>
                    <option value="Réservé" <%= puppy.status === 'Réservé' ? 'selected' : '' %>>Réservé</option>
                    <option value="Vendu" <%= puppy.status === 'Vendu' ? 'selected' : '' %>>Vendu</option>
                    <option value="Décédé" <%= puppy.status === 'Décédé' ? 'selected' : '' %>>Décédé</option>
                </select>
            </div>
            <div class="form-group">
                <label>Prix de vente attendu</label>
                <input type="number" step="0.01" name="sale_price" value="<%= puppy.sale_price || '' %>">
            </div>
        </div>

        <div class="form-group" style="margin-top: 1rem;">
            <label>Notes & Particularités</label>
            <textarea name="notes" rows="3"><%= puppy.notes || '' %></textarea>
        </div>

        <div style="margin-top: 2rem;">
            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem;">Enregistrer le chiot</button>
        </div>
    </form>
</main>

<%- include('../partials/foot') %>