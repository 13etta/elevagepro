<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="container">
  <section class="page-hero">
    <div>
      <p class="eyebrow">Échéance</p>
      <h1><%= reminder.id ? 'Modifier le rappel' : 'Ajouter un rappel' %></h1>
      <p>Créez une échéance rattachée à un chien ou à l’élevage : soin, vaccin, vermifuge, reproduction, document ou action administrative.</p>
    </div>
    <a class="btn btn-secondary" href="/reminders">Retour aux rappels</a>
  </section>

  <section class="card">
    <form action="<%= reminder.id ? '/reminders/' + reminder.id + '/edit' : '/reminders/new' %>" method="POST" class="stacked-form">
      <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div class="form-group">
          <label for="title">Libellé du rappel *</label>
          <input type="text" id="title" name="title" value="<%= reminder.title || '' %>" required placeholder="Ex : Rappel Milbemax, échographie, vaccin...">
        </div>

        <div class="form-group">
          <label for="due_date">Date d’échéance *</label>
          <input type="date" id="due_date" name="due_date" value="<%= reminder.due_date ? new Date(reminder.due_date).toISOString().split('T')[0] : '' %>" required>
        </div>
      </div>

      <div class="form-grid" style="grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div class="form-group">
          <label for="type">Type</label>
          <select id="type" name="type">
            <option value="general" <%= reminder.type === 'general' ? 'selected' : '' %>>Général</option>
            <option value="vaccin" <%= reminder.type === 'vaccin' ? 'selected' : '' %>>Vaccin</option>
            <option value="vermifuge" <%= reminder.type === 'vermifuge' ? 'selected' : '' %>>Vermifuge</option>
            <option value="antiparasitaire" <%= reminder.type === 'antiparasitaire' ? 'selected' : '' %>>Antiparasitaire</option>
            <option value="reproduction" <%= reminder.type === 'reproduction' ? 'selected' : '' %>>Reproduction</option>
            <option value="document" <%= reminder.type === 'document' ? 'selected' : '' %>>Document</option>
            <option value="administratif" <%= reminder.type === 'administratif' ? 'selected' : '' %>>Administratif</option>
          </select>
        </div>

        <div class="form-group">
          <label for="dog_id">Chien concerné</label>
          <select id="dog_id" name="dog_id">
            <option value="">Général / non rattaché</option>
            <% dogs.forEach((dog) => { %>
              <option value="<%= dog.id %>" <%= reminder.dog_id === dog.id ? 'selected' : '' %>><%= dog.name %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Enregistrer le rappel</button>
      </div>
    </form>
  </section>
</main>

<%- include('../partials/foot') %>
